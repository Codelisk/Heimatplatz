  function scalarValue(value: string | string[] | number | null | undefined) {
    if (Array.isArray(value)) return value[0] ?? "";
    return value ?? "";
  }

  function toNumber(value: string | string[] | number | null | undefined) {
    const scalar = scalarValue(value);
    const parsed = Number(scalar);
    return Number.isFinite(parsed) && parsed > 0 ? parsed : null;
  }

  function requiredText(value: string | string[] | number | null | undefined) {
    return String(scalarValue(value) ?? "").trim();
  }

  function mapPropertyType(value: string | undefined) {
    if (value === "land") return "Land";
    if (value === "foreclosure") return "Foreclosure";
    return "House";
  }

  function mapApiPropertyType(value: string | undefined) {
    if (value === "Land") return "land";
    if (value === "Foreclosure") return "foreclosure";
    return "house";
  }

  function hasStructureFields(draft: Draft) {
    return draft.propertyType !== "land";
  }

  function toIsoDateTime(value: string | string[] | undefined) {
    const scalar = scalarValue(value);
    if (!scalar) return null;
    const date = new Date(scalar);
    return Number.isFinite(date.valueOf()) ? date.toISOString() : null;
  }

  function toDateTimeLocal(value: unknown) {
    if (!value || typeof value !== "string") return "";
    const date = new Date(value);
    if (!Number.isFinite(date.valueOf())) return "";
    const pad = (number: number) => String(number).padStart(2, "0");
    return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}`;
  }

  function readTypeSpecificData(property: ApiProperty) {
    if (!property.TypeSpecificData) return {};
    if (typeof property.TypeSpecificData === "object") return property.TypeSpecificData;
    try {
      const parsed = JSON.parse(property.TypeSpecificData);
      return parsed && typeof parsed === "object" ? parsed as Record<string, unknown> : {};
    } catch {
      return {};
    }
  }

  function readTypedString(data: Record<string, unknown>, key: string) {
    const value = data[key];
    if (value === null || value === undefined) return "";
    return String(value);
  }

  function buildForeclosureTypeSpecificData(draft: Draft) {
    if (draft.propertyType !== "foreclosure") return null;

    return {
      CourtName: scalarValue(draft.foreclosureCourtName),
      AuctionDate: toIsoDateTime(draft.foreclosureAuctionDate) || new Date().toISOString(),
      MinimumBid: toNumber(draft.foreclosureMinimumBid) ?? 0,
      EstimatedValue: toNumber(draft.foreclosureEstimatedValue),
      Encumbrances: [],
      Status: scalarValue(draft.foreclosureStatus) || "Scheduled",
      FileNumber: scalarValue(draft.foreclosureFileNumber),
      RegistrationNumber: scalarValue(draft.foreclosureRegistrationNumber) || null,
      CadastralMunicipality: scalarValue(draft.foreclosureCadastralMunicipality) || null,
      PlotNumber: scalarValue(draft.foreclosurePlotNumber) || null,
      TotalArea: toNumber(draft.foreclosureTotalArea) ?? toNumber(draft.plotArea),
      BuildingArea: toNumber(draft.foreclosureBuildingArea),
      ZoningDesignation: scalarValue(draft.foreclosureZoningDesignation) || null,
      BuildingCondition: scalarValue(draft.foreclosureBuildingCondition) || null,
      NumberOfRooms: toNumber(draft.rooms),
      YearBuilt: toNumber(draft.yearBuilt),
      ViewingDate: toIsoDateTime(draft.foreclosureViewingDate),
      BiddingDeadline: toIsoDateTime(draft.foreclosureBiddingDeadline),
      OwnershipShare: scalarValue(draft.foreclosureOwnershipShare) || null,
      Notes: scalarValue(draft.foreclosureNotes) || null,
      EdictUrl: scalarValue(draft.foreclosureEdictUrl) || null,
      FloorPlanUrl: null,
      SitePlanUrl: null,
      LongAppraisalUrl: null,
      ShortAppraisalUrl: null,
    };
  }

  function validatePropertyDraft(draft: Draft) {
    if (requiredText(draft.title).length < 10) return "Titel muss mindestens 10 Zeichen lang sein.";
    if (requiredText(draft.description).length < 50) return "Beschreibung muss mindestens 50 Zeichen lang sein.";
    if (!toNumber(draft.price)) return "Bitte geben Sie einen gueltigen Preis ein.";
    if (!requiredText(draft.address)) return "Bitte geben Sie eine Strasse ein.";
    if (!requiredText(draft.city) || !requiredText(draft.postalCode)) return "Bitte waehlen Sie einen Ort aus.";
    if (!/^\d{4}$/.test(requiredText(draft.postalCode))) return "Bitte geben Sie eine gueltige vierstellige PLZ ein.";

    if (draft.propertyType !== "foreclosure") return "";
    if (!draft.foreclosureCourtName) return "Bitte das zuständige Gericht angeben.";
    if (!draft.foreclosureFileNumber) return "Bitte das Aktenzeichen angeben.";
    if (!toIsoDateTime(draft.foreclosureAuctionDate)) return "Bitte einen gueltigen Versteigerungstermin angeben.";
    if (!toNumber(draft.foreclosureMinimumBid)) return "Bitte ein Mindestgebot groesser als 0 angeben.";
    return "";
  }

  function mapSellerType(value: string | undefined) {
    return value === "Broker" ? "Broker" : "Private";
  }

  function normalizeText(value: string | undefined) {
    return (value ?? "")
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .toLowerCase()
      .trim();
  }

  async function loadMunicipalities() {
    if (!municipalityPromise) {
      municipalityPromise = apiRequest<LocationsResponse>("/api/locations").then((locations) =>
        locations.FederalProvinces
          .flatMap((province) => province.Districts)
          .flatMap((district) =>
            district.Municipalities.map((municipality) => ({
              ...municipality,
              DistrictName: district.Name,
            })),
          )
          .sort((a, b) => `${a.PostalCode} ${a.Name}`.localeCompare(`${b.PostalCode} ${b.Name}`, "de-AT")),
      );
    }

    return municipalityPromise;
  }

  function setLocationStatus(form: HTMLFormElement, message: string, tone: "info" | "error" = "info") {
    const status = form.querySelector<HTMLElement>("[data-location-status]");
    if (!status) return;
    status.textContent = message;
    status.classList.toggle("text-red-700", tone === "error");
    status.classList.toggle("text-muted-foreground", tone === "info");
  }

  function applyMunicipalityToForm(form: HTMLFormElement, municipality: Municipality) {
    setField(form, "municipalityId", municipality.Id);
    setField(form, "city", municipality.Name);
    setField(form, "postalCode", municipality.PostalCode);
  }

  function syncLocationSelect(form: HTMLFormElement) {
    const select = form.querySelector<HTMLSelectElement>("[data-location-select]");
    if (!select || select.options.length <= 1) return;

    const municipalityId = String((form.elements.namedItem("municipalityId") as HTMLInputElement | null)?.value ?? "");
    if (municipalityId) {
      select.value = municipalityId;
      return;
    }

    const city = normalizeText(String((form.elements.namedItem("city") as HTMLInputElement | null)?.value ?? ""));
    const postalCode = String((form.elements.namedItem("postalCode") as HTMLInputElement | null)?.value ?? "").trim();
    const option = Array.from(select.options).find((item) =>
      normalizeText(item.dataset.name) === city && (!postalCode || item.dataset.postalCode === postalCode)
    );
    if (option) {
      select.value = option.value;
      setField(form, "municipalityId", option.value);
    }
  }

  async function populateLocationSelects() {
    const forms = Array.from(document.querySelectorAll<HTMLFormElement>("[data-local-property-form]"));
    if (forms.length === 0) return;

    try {
      const municipalities = await loadMunicipalities();
      forms.forEach((form) => {
        const select = form.querySelector<HTMLSelectElement>("[data-location-select]");
        if (!select) return;

        select.textContent = "";
        select.append(new Option("Ort auswaehlen", ""));
        municipalities.forEach((municipality) => {
          const option = new Option(`${municipality.PostalCode} ${municipality.Name} (${municipality.DistrictName})`, municipality.Id);
          option.dataset.name = municipality.Name;
          option.dataset.postalCode = municipality.PostalCode;
          select.append(option);
        });

        syncLocationSelect(form);
        setLocationStatus(form, "Ort auswaehlen oder Ort/PLZ manuell eintragen.");
      });
    } catch (error) {
      forms.forEach((form) => {
        const select = form.querySelector<HTMLSelectElement>("[data-location-select]");
        if (select) {
          select.textContent = "";
          select.append(new Option("Ort manuell eintragen", ""));
        }
        setLocationStatus(
          form,
          error instanceof Error ? `Orte konnten nicht geladen werden: ${error.message}` : "Orte konnten nicht geladen werden.",
          "error",
        );
      });
    }
  }

  function bindLocationPickers() {
    document.querySelectorAll<HTMLFormElement>("[data-local-property-form]").forEach((form) => {
      const select = form.querySelector<HTMLSelectElement>("[data-location-select]");
      select?.addEventListener("change", async () => {
        if (!select.value) return;
        const municipality = (await loadMunicipalities()).find((item) => item.Id === select.value);
        if (municipality) applyMunicipalityToForm(form, municipality);
      });
    });

    void populateLocationSelects();
  }

  async function findMunicipalityId(draft: Draft) {
    if (draft.municipalityId && UUID_PATTERN.test(draft.municipalityId)) {
      return draft.municipalityId;
    }

    const city = normalizeText(draft.city);
    const postalCode = draft.postalCode?.trim();
    const municipalities = await loadMunicipalities();

    const exact = municipalities.find((municipality) =>
      normalizeText(municipality.Name) === city &&
      (!postalCode || municipality.PostalCode === postalCode)
    );
    return exact?.Id ?? municipalities.find((municipality) => normalizeText(municipality.Name) === city)?.Id ?? null;
  }

  async function createRemoteProperty(draft: Draft, imageUrls: string[]) {
    const session = readSession();
    if (!session) return null;

    const municipalityId = await findMunicipalityId(draft);
    if (!municipalityId) {
      throw new Error("Der Ort konnte nicht eindeutig in Oberoesterreich gefunden werden.");
    }

    const response = await apiRequest<{ PropertyId: string; Title: string; CreatedAt: string }>("/api/properties", {
      method: "POST",
      body: {
        Title: draft.title,
        Address: draft.address,
        MunicipalityId: municipalityId,
        Price: toNumber(draft.price),
        Type: mapPropertyType(draft.propertyType),
        SellerType: draft.sellerType || "Private",
        SellerName: draft.sellerName || session.FullName || "Privatanbieter",
        Description: draft.description || null,
        LivingAreaSquareMeters: hasStructureFields(draft) ? toNumber(draft.livingArea) : null,
        PlotAreaSquareMeters: toNumber(draft.plotArea),
        Rooms: hasStructureFields(draft) ? toNumber(draft.rooms) : null,
        YearBuilt: hasStructureFields(draft) ? toNumber(draft.yearBuilt) : null,
        Features: [],
        ImageUrls: imageUrls,
        TypeSpecificData: buildForeclosureTypeSpecificData(draft),
      },
    });

    return response;
  }

  async function updateRemoteProperty(id: string, draft: Draft, imageUrls: string[]) {
    const session = readSession();
    if (!session || !UUID_PATTERN.test(id)) return null;

    const municipalityId = await findMunicipalityId(draft);
    if (!municipalityId) {
      throw new Error("Der Ort konnte nicht eindeutig in Oberoesterreich gefunden werden.");
    }

    const response = await apiRequest<{ Success: boolean }>("/api/properties", {
      method: "PUT",
      body: {
        Id: id,
        Title: draft.title,
        Address: draft.address,
        MunicipalityId: municipalityId,
        Price: toNumber(draft.price),
        Type: mapPropertyType(draft.propertyType),
        SellerType: mapSellerType(draft.sellerType),
        SellerName: draft.sellerName || session.FullName || "Privatanbieter",
        Description: draft.description || null,
        LivingAreaSquareMeters: hasStructureFields(draft) ? toNumber(draft.livingArea) : null,
        PlotAreaSquareMeters: toNumber(draft.plotArea),
        Rooms: hasStructureFields(draft) ? toNumber(draft.rooms) : null,
        YearBuilt: hasStructureFields(draft) ? toNumber(draft.yearBuilt) : null,
        Features: [],
        ImageUrls: imageUrls,
        TypeSpecificData: buildForeclosureTypeSpecificData(draft),
      },
    });

    return response;
  }

  function saveLocalDraft(draft: Draft, editId: string | null) {
    const drafts = readArray<Draft>(STORAGE_KEYS.drafts);
    if (editId) {
      const existingIndex = drafts.findIndex((item) => item.id === editId);
      draft.id = editId;
      if (existingIndex >= 0) {
        drafts[existingIndex] = draft;
        writeArray(STORAGE_KEYS.drafts, drafts);
        return;
      }
    }

    writeArray(STORAGE_KEYS.drafts, [draft, ...drafts]);
  }

  function setField(form: HTMLFormElement, name: string, value: string | number | null | undefined) {
    const field = form.elements.namedItem(name);
    if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement) {
      field.value = value === null || value === undefined ? "" : String(value);
    }
  }

  function updatePropertyTypeFields(form: HTMLFormElement) {
    const type = form.elements.namedItem("propertyType");
    const propertyType = type instanceof HTMLSelectElement ? type.value : "house";
    const isLand = propertyType === "land";
    const isForeclosure = propertyType === "foreclosure";
    const foreclosureFields = form.querySelector<HTMLElement>("[data-foreclosure-fields]");

    form.querySelectorAll<HTMLElement>("[data-structure-property-field]").forEach((element) => {
      element.hidden = isLand;
      element
        .querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>("input, textarea, select")
        .forEach((field) => {
          field.disabled = isLand;
        });
    });

    if (foreclosureFields) {
      foreclosureFields.hidden = !isForeclosure;
      foreclosureFields
        .querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>("input, textarea, select")
        .forEach((field) => {
          field.disabled = !isForeclosure;
          field.required = isForeclosure && field.hasAttribute("data-foreclosure-required");
        });
    }
  }

  function bindPropertyTypeFields() {
    document.querySelectorAll<HTMLFormElement>("[data-local-property-form]").forEach((form) => {
      const type = form.elements.namedItem("propertyType");
      if (type instanceof HTMLSelectElement) {
        type.addEventListener("change", () => updatePropertyTypeFields(form));
      }
      updatePropertyTypeFields(form);
    });
  }

  function fillPropertyForm(form: HTMLFormElement, draft: Draft) {
    setField(form, "propertyType", draft.propertyType);
    setField(form, "sellerName", draft.sellerName);
    setField(form, "sellerType", draft.sellerType);
    setField(form, "title", draft.title);
    setField(form, "description", draft.description);
    setField(form, "address", draft.address);
    setField(form, "city", draft.city);
    setField(form, "postalCode", draft.postalCode);
    setField(form, "price", draft.price);
    setField(form, "livingArea", draft.livingArea);
    setField(form, "plotArea", draft.plotArea);
    setField(form, "rooms", draft.rooms);
    setField(form, "yearBuilt", draft.yearBuilt);
    setField(form, "municipalityId", draft.municipalityId);
    [
      "foreclosureCourtName",
      "foreclosureFileNumber",
      "foreclosureAuctionDate",
      "foreclosureMinimumBid",
      "foreclosureEstimatedValue",
      "foreclosureStatus",
      "foreclosureViewingDate",
      "foreclosureBiddingDeadline",
      "foreclosureOwnershipShare",
      "foreclosureEdictUrl",
      "foreclosureRegistrationNumber",
      "foreclosureCadastralMunicipality",
      "foreclosurePlotNumber",
      "foreclosureTotalArea",
      "foreclosureBuildingArea",
      "foreclosureZoningDesignation",
      "foreclosureBuildingCondition",
      "foreclosureNotes",
    ].forEach((field) => setField(form, field, draft[field] as string | undefined));
    updatePropertyTypeFields(form);
    setFormImages(form, getDraftImageUrls(draft));
    syncLocationSelect(form);
  }

  function apiPropertyToDraft(property: ApiProperty) {
    const typeSpecificData = readTypeSpecificData(property);
    return {
      id: property.Id,
      title: property.Title,
      description: property.Description ?? "",
      propertyType: mapApiPropertyType(property.Type),
      sellerName: property.SellerName,
      sellerType: mapSellerType(property.SellerType ?? undefined),
      address: property.Address,
      city: property.City,
      postalCode: property.PostalCode,
      price: String(property.Price ?? ""),
      livingArea: property.LivingAreaM2 ? String(property.LivingAreaM2) : "",
      plotArea: property.PlotAreaM2 ? String(property.PlotAreaM2) : "",
      rooms: property.Rooms ? String(property.Rooms) : "",
      yearBuilt: property.YearBuilt ? String(property.YearBuilt) : "",
      municipalityId: property.MunicipalityId ?? "",
      imageUrls: property.ImageUrls ?? [],
      foreclosureCourtName: readTypedString(typeSpecificData, "CourtName"),
      foreclosureFileNumber: readTypedString(typeSpecificData, "FileNumber"),
      foreclosureAuctionDate: toDateTimeLocal(typeSpecificData.AuctionDate),
      foreclosureMinimumBid: readTypedString(typeSpecificData, "MinimumBid"),
      foreclosureEstimatedValue: readTypedString(typeSpecificData, "EstimatedValue"),
      foreclosureStatus: readTypedString(typeSpecificData, "Status") || "Scheduled",
      foreclosureViewingDate: toDateTimeLocal(typeSpecificData.ViewingDate),
      foreclosureBiddingDeadline: toDateTimeLocal(typeSpecificData.BiddingDeadline),
      foreclosureOwnershipShare: readTypedString(typeSpecificData, "OwnershipShare"),
      foreclosureEdictUrl: readTypedString(typeSpecificData, "EdictUrl"),
      foreclosureRegistrationNumber: readTypedString(typeSpecificData, "RegistrationNumber"),
      foreclosureCadastralMunicipality: readTypedString(typeSpecificData, "CadastralMunicipality"),
      foreclosurePlotNumber: readTypedString(typeSpecificData, "PlotNumber"),
      foreclosureTotalArea: readTypedString(typeSpecificData, "TotalArea"),
      foreclosureBuildingArea: readTypedString(typeSpecificData, "BuildingArea"),
      foreclosureZoningDesignation: readTypedString(typeSpecificData, "ZoningDesignation"),
      foreclosureBuildingCondition: readTypedString(typeSpecificData, "BuildingCondition"),
      foreclosureNotes: readTypedString(typeSpecificData, "Notes"),
    } satisfies Draft;
  }

  async function hydratePropertyEditForm() {
    const form = document.querySelector<HTMLFormElement>("[data-edit-property-form]");
    if (!form) return;

    const params = new URLSearchParams(window.location.search);
    const draftId = params.get("draft");
    const remoteId = params.get("id");

    if (draftId) {
      const draft = readArray<Draft>(STORAGE_KEYS.drafts).find((item) => item.id === draftId);
      if (draft) {
        fillPropertyForm(form, draft);
        setFormStatus(form, "Lokaler Entwurf geladen.");
      }
      return;
    }

    if (!remoteId || !UUID_PATTERN.test(remoteId)) return;

    setFormStatus(form, "Immobilie wird geladen...");
    try {
      const response = await apiRequest<{ Property: ApiProperty | null }>(`/api/properties/${remoteId}`);
      if (response.Property) {
        fillPropertyForm(form, apiPropertyToDraft(response.Property));
        setFormStatus(form, "Immobilie geladen.", "success");
      } else {
        setFormStatus(form, "Immobilie nicht gefunden.", "error");
      }
    } catch (error) {
      setFormStatus(
        form,
        error instanceof Error ? `Immobilie konnte nicht geladen werden: ${error.message}` : "Immobilie konnte nicht geladen werden.",
        "error",
      );
    }
  }

  function renderDrafts() {
    const drafts = readArray<Draft>(STORAGE_KEYS.drafts);
    document.querySelectorAll<HTMLElement>("[data-local-drafts]").forEach((container) => {
      container.textContent = "";
      drafts.forEach((draft) => container.append(createDraftCard(draft)));
      container.classList.toggle("hidden", drafts.length === 0);

      const empty = container.closest("[data-user-page]")?.querySelector("[data-user-empty]");
      empty?.classList.toggle("hidden", drafts.length > 0);
    });
  }

  function renderMineStatus() {
    const status = document.querySelector<HTMLElement>("[data-mine-status]");
    const text = document.querySelector<HTMLElement>("[data-mine-status-text]");
    if (!status || !text) return;

    const params = new URLSearchParams(window.location.search);
    const message = params.has("bearbeitet")
      ? "Aenderungen gespeichert."
      : params.has("gespeichert")
        ? "Entwurf gespeichert."
        : "";

    text.textContent = message;
    status.classList.toggle("hidden", !message);
  }

  function bindFallbackImages() {
    document.querySelectorAll<HTMLImageElement>("[data-fallback-image]").forEach((image) => {
      image.addEventListener("error", () => {
        image.src = image.dataset.fallbackImage || "/og/heimatplatz-default.svg";
      }, { once: true });
    });
  }

  async function renderRemoteUserLists() {
    const session = readSession();
    if (!session) return;

    const endpoints: Record<string, string> = {
      favorites: "/api/favorites",
      blocked: "/api/blocked",
      mine: "/api/properties/user",
    };

    document.querySelectorAll<HTMLElement>("[data-remote-properties]").forEach(async (container) => {
      const mode = container.getAttribute("data-remote-mode") ?? "";
      const endpoint = endpoints[mode];
      if (!endpoint) return;

      try {
        const response = await apiRequest<{ Properties: ApiProperty[] }>(endpoint);
        const properties = response.Properties ?? [];
        container.textContent = "";
        properties.forEach((property) => container.append(createApiPropertyCard(property, mode)));
        container.classList.toggle("hidden", properties.length === 0);

        const empty = container.closest("[data-user-page]")?.querySelector("[data-user-empty]");
        empty?.classList.toggle("hidden", properties.length > 0);
      } catch (error) {
        console.warn("[Heimatplatz] API user list load failed", error);
      }
    });
  }

  function bindPropertyForm() {
    document.querySelectorAll<HTMLFormElement>("[data-local-property-form]").forEach((form) => {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!form.reportValidity()) return;

        const submit = form.querySelector<HTMLButtonElement>("[type='submit']");
        const params = new URLSearchParams(window.location.search);
        const editId = params.get("id") ?? params.get("draft");
        const isEditForm = form.hasAttribute("data-edit-property-form");
        const formData = new FormData(form);
        const draft: Draft = {};
        formData.forEach((value, key) => {
          if (key === "propertyImages" || key === "municipalityLookup" || key === "imageUrls") return;
          draft[key] = typeof value === "string" ? value : value.name;
        });
        draft.id = editId ?? crypto.randomUUID?.() ?? `${Date.now()}`;
        draft.updatedAt = new Date().toISOString();

        const validationMessage = validatePropertyDraft(draft);
        if (validationMessage) {
          setFormStatus(form, validationMessage, "error");
          return;
        }

        if (!isEditForm && getImageState(form).length === 0) {
          setFormStatus(form, "Bitte fuegen Sie mindestens ein Foto hinzu.", "error");
          return;
        }

        submit?.setAttribute("disabled", "true");
        setFormStatus(form, editId ? "Aenderungen werden gespeichert..." : readSession() ? "Inserat wird gespeichert..." : "Entwurf wird lokal gespeichert...");

        try {
          if (editId && UUID_PATTERN.test(editId) && readSession()) {
            setFormStatus(form, "Bilder werden hochgeladen...");
            const imageUrls = await uploadImages(form, false);
            draft.imageUrls = imageUrls;
            const updated = await updateRemoteProperty(editId, draft, imageUrls);
            if (updated) {
              window.location.href = "/meine-immobilien/?gespeichert=api";
              return;
            }
          }

          if (!editId) {
            let imageUrls = await getLocalImageUrls(form);
            if (readSession()) {
              setFormStatus(form, "Bilder werden hochgeladen...");
              imageUrls = await uploadImages(form, true);
            }
            draft.imageUrls = imageUrls;
            const remote = await createRemoteProperty(draft, imageUrls);
            if (remote?.PropertyId) {
              window.location.href = "/meine-immobilien/?gespeichert=api";
              return;
            }
          }

          draft.imageUrls = await getLocalImageUrls(form);
          saveLocalDraft(draft, editId);
          window.location.href = editId ? "/meine-immobilien/?bearbeitet=1" : "/meine-immobilien/?gespeichert=1";
        } catch (error) {
          draft.imageUrls = await getLocalImageUrls(form);
          saveLocalDraft(draft, editId);
          if (editId) {
            setFormStatus(
              form,
              error instanceof Error
                ? `Online-Aktualisierung fehlgeschlagen, Entwurf lokal gesichert: ${error.message}`
                : "Online-Aktualisierung fehlgeschlagen, Entwurf lokal gesichert.",
              "error",
            );
          } else {
            setFormStatus(
              form,
              error instanceof Error
                ? `Online-Speichern fehlgeschlagen, Entwurf lokal gesichert: ${error.message}`
                : "Online-Speichern fehlgeschlagen, Entwurf lokal gesichert.",
              "error",
            );
          }
        } finally {
          submit?.removeAttribute("disabled");
        }
      });
    });
  }

  async function deleteRemoteProperty(id: string, button: HTMLButtonElement) {
    if (!readSession() || !UUID_PATTERN.test(id)) return;
    const card = button.closest("article");
    button.setAttribute("disabled", "true");

    try {
      await apiRequest(`/api/properties/${id}`, { method: "DELETE" });
      card?.remove();
      document.querySelectorAll<HTMLElement>("[data-remote-properties]").forEach((container) => {
        const empty = container.closest("[data-user-page]")?.querySelector("[data-user-empty]");
        empty?.classList.toggle("hidden", container.querySelectorAll("article").length > 0);
      });
    } catch (error) {
      window.alert(error instanceof Error ? error.message : "Die Immobilie konnte nicht geloescht werden.");
      button.removeAttribute("disabled");
    }
  }

  async function shareUrl(button: HTMLButtonElement) {
    const url = button.getAttribute("data-share-url") || window.location.href;
    const title = button.getAttribute("data-share-title") || document.title;
    try {
      if (navigator.share) {
        await navigator.share({ title, url });
      } else {
        await navigator.clipboard.writeText(url);
      }
      button.setAttribute("data-copied", "true");
      window.setTimeout(() => button.removeAttribute("data-copied"), 1600);
    } catch {
      // Sharing is user-controlled and can be cancelled without affecting the page.
    }
  }

  async function copyText(button: HTMLButtonElement) {
    const value = button.getAttribute("data-copy-value");
    if (!value) return;

    try {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(value);
      } else {
        const input = document.createElement("textarea");
        input.value = value;
        input.setAttribute("readonly", "true");
        input.style.position = "fixed";
        input.style.left = "-9999px";
        document.body.append(input);
        input.select();
        const legacyDocument = document as unknown as { execCommand(commandId: string): boolean };
        legacyDocument.execCommand("copy");
        input.remove();
      }

      const text = button.querySelector<HTMLElement>("[data-copy-text]");
      const originalText = text?.textContent;
      const originalLabel = button.getAttribute("aria-label");
      button.setAttribute("data-copied", "true");
      button.setAttribute("aria-label", "Kopiert");
      if (text) text.textContent = "Kopiert";

      window.setTimeout(() => {
        button.removeAttribute("data-copied");
        if (text && originalText) text.textContent = originalText;
        if (originalLabel) button.setAttribute("aria-label", originalLabel);
      }, 1600);
    } catch {
      const text = button.querySelector<HTMLElement>("[data-copy-text]");
      const originalText = text?.textContent;
      if (text) text.textContent = "Nicht kopiert";
      window.setTimeout(() => {
        if (text && originalText) text.textContent = originalText;
      }, 1600);
    }
  }

  function bindGlobalActions() {
    document.addEventListener("click", (event) => {
      const target = event.target instanceof Element ? event.target : null;
      const menuButton = target?.closest("[data-card-action]");
      if (menuButton instanceof HTMLButtonElement) {
        const menuId = menuButton.getAttribute("aria-controls");
        const menu = menuId ? document.getElementById(menuId) : null;
        const willOpen = menu?.classList.contains("hidden") ?? false;
        closeCardMenus(menu instanceof HTMLElement ? menu : null);

        if (menu instanceof HTMLElement) {
          menu.classList.toggle("hidden", !willOpen);
          menuButton.setAttribute("aria-expanded", String(willOpen));
        }
        return;
      }

      const actionButton = target?.closest("[data-property-action]");
      if (actionButton instanceof HTMLButtonElement) {
        const action = actionButton.getAttribute("data-property-action");
        const slug = actionButton.getAttribute("data-property-slug");
        const propertyId = actionButton.getAttribute("data-property-id");
        if (!slug) return;
        let active = false;

        if (action === "favorite") {
          active = toggleValue(STORAGE_KEYS.favorites, slug);
          if (active) removeValue(STORAGE_KEYS.blocked, slug);
        }
        if (action === "block") {
          active = toggleValue(STORAGE_KEYS.blocked, slug);
          if (active) removeValue(STORAGE_KEYS.favorites, slug);
        }

        refreshActionButtons();
        syncUserLists();
        closeCardMenus();
        void syncRemotePropertyAction(action, propertyId, active);
        return;
      }

      const remove = target?.closest("[data-draft-remove]");
      if (remove instanceof HTMLButtonElement) {
        const id = remove.getAttribute("data-draft-remove");
        const drafts = readArray<Draft>(STORAGE_KEYS.drafts).filter((draft) => draft.id !== id);
        writeArray(STORAGE_KEYS.drafts, drafts);
        renderDrafts();
        return;
      }

      const remoteDelete = target?.closest("[data-remote-delete]");
      if (remoteDelete instanceof HTMLButtonElement) {
        const id = remoteDelete.getAttribute("data-remote-delete");
        if (id && window.confirm("Immobilie wirklich loeschen?")) {
          void deleteRemoteProperty(id, remoteDelete);
        }
        return;
      }

      const copy = target?.closest("[data-copy-value]");
      if (copy instanceof HTMLButtonElement) {
        void copyText(copy);
        return;
      }

      const share = target?.closest("[data-share-url]");
      if (share instanceof HTMLButtonElement) {
        void shareUrl(share);
        return;
      }

      const logout = target?.closest("[data-logout]");
      if (logout instanceof HTMLButtonElement) {
        clearSession();
        if (window.location.pathname === "/profil/") {
          window.location.href = "/anmelden/";
        }
      }

      const deleteAccount = target?.closest("[data-delete-account]");
      if (deleteAccount instanceof HTMLButtonElement) {
        void handleDeleteAccount(deleteAccount);
        return;
      }

      if (!target?.closest("[data-card-menu]")) {
        closeCardMenus();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeCardMenus();
      }
    });
  }

  function bootPropertyState() {
    refreshActionButtons();
    bindFallbackImages();
    renderAuthState();
    syncUserLists();
    renderMineStatus();
    renderDrafts();
    void renderRemoteUserLists();
    applySavedPreferences();
    bindNotificationPreferenceVisibility();
    bindRegisterRoleFields();
    bindImagePickers();
    bindLocationPickers();
    bindPropertyTypeFields();
    void hydratePropertyEditForm();
    bindAuthForms();
    bindPreferenceForms();
    bindPropertyForm();
    bindGlobalActions();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bootPropertyState, { once: true });
  } else {
    bootPropertyState();
  }
</script>
