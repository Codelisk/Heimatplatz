<script>
  type Draft = {
    id?: string;
    updatedAt?: string;
    title?: string;
    propertyType?: string;
    sellerName?: string;
    sellerType?: string;
    description?: string;
    municipalityId?: string;
    postalCode?: string;
    city?: string;
    address?: string;
    price?: string;
    livingArea?: string;
    plotArea?: string;
    rooms?: string;
    yearBuilt?: string;
    imageUrls?: string[];
    [key: string]: string | string[] | undefined;
  };

  type Session = {
    AccessToken: string;
    RefreshToken: string;
    UserId: string;
    Email: string;
    FullName: string;
    ExpiresAt: string;
  };

  type RequestOptions = Omit<RequestInit, "body"> & {
    body?: unknown;
    skipAuth?: boolean;
  };

  type ApiProperty = {
    Id: string;
    Title: string;
    Address: string;
    MunicipalityId?: string;
    City: string;
    PostalCode: string;
    Price: number | string;
    LivingAreaM2?: number | string | null;
    PlotAreaM2?: number | string | null;
    Rooms?: number | string | null;
    Type: string;
    SellerType: string | null;
    SellerName: string;
    ImageUrls: string[];
    CreatedAt: string;
    SourceName?: string | null;
    Description?: string | null;
    YearBuilt?: number | string | null;
    TypeSpecificData?: string | Record<string, unknown> | null;
  };

  type Municipality = {
    Id: string;
    Name: string;
    PostalCode: string;
    DistrictName: string;
  };

  type LocationsResponse = {
    FederalProvinces: Array<{
      Districts: Array<{
        Name: string;
        Municipalities: Array<{ Id: string; Name: string; PostalCode: string }>;
      }>;
    }>;
  };

  type PropertyImageItem = {
    id: string;
    url: string;
    fileName: string;
    contentType: string;
    existing: boolean;
    file?: File;
  };

  const STORAGE_KEYS = {
    session: "heimatplatz:session",
    favorites: "heimatplatz:favorites",
    blocked: "heimatplatz:blocked",
    drafts: "heimatplatz:property-drafts",
    notificationPreferences: "heimatplatz:notification-preferences",
    filterPreferences: "heimatplatz:filter-preferences",
  };

  const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL || "https://heimatplatz-api.azurewebsites.net";
  const UUID_PATTERN = /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i;
  const MAX_PROPERTY_IMAGES = 20;
  const imageFormState = new WeakMap<HTMLFormElement, PropertyImageItem[]>();
  let municipalityPromise: Promise<Municipality[]> | null = null;

  function readArray<T = string>(key: string): T[] {
    try {
      const value = window.localStorage.getItem(key);
      const parsed = value ? JSON.parse(value) : [];
      return Array.isArray(parsed) ? parsed as T[] : [];
    } catch {
      return [];
    }
  }

  function writeArray<T>(key: string, value: T[]) {
    try {
      window.localStorage.setItem(key, JSON.stringify(value));
    } catch {
      // Local storage can be disabled; the UI should still remain usable.
    }
  }

  function readJson<T>(key: string): T | null {
    try {
      const value = window.localStorage.getItem(key);
      return value ? JSON.parse(value) as T : null;
    } catch {
      return null;
    }
  }

  function writeJson<T>(key: string, value: T) {
    try {
      window.localStorage.setItem(key, JSON.stringify(value));
    } catch {
      // Local storage can be disabled; the UI should still remain usable.
    }
  }

  function readSession() {
    const session = readJson<Session>(STORAGE_KEYS.session);
    if (!session?.AccessToken) return null;

    if (session.ExpiresAt && new Date(session.ExpiresAt).getTime() <= Date.now()) {
      window.localStorage.removeItem(STORAGE_KEYS.session);
      return null;
    }

    return session;
  }

  function readSessionRoles(session: Session | null) {
    const roles = new Set<string>();
    if (!session?.AccessToken) return roles;

    try {
      const payload = session.AccessToken.split(".")[1];
      if (!payload) return roles;
      const padded = payload.replace(/-/g, "+").replace(/_/g, "/").padEnd(Math.ceil(payload.length / 4) * 4, "=");
      const parsed = JSON.parse(window.atob(padded)) as Record<string, unknown>;
      const roleClaim = parsed.user_role;
      const values = Array.isArray(roleClaim) ? roleClaim : [roleClaim];
      values.forEach((role) => {
        if (typeof role === "string") roles.add(role.toLowerCase());
      });
    } catch {
      // Role badges are a progressive enhancement; authentication itself does not depend on this.
    }

    return roles;
  }

  function getInitials(fullName: string | undefined) {
    const parts = (fullName ?? "").trim().split(/\s+/).filter(Boolean);
    if (parts.length === 0) return "?";
    if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
    return `${parts[0][0]}${parts[parts.length - 1][0]}`.toUpperCase();
  }

  function getRoleBadgeText(roles: Set<string>) {
    const isBuyer = roles.has("buyer");
    const isSeller = roles.has("seller");
    if (isBuyer && isSeller) return "Kaeufer & Verkaeufer";
    if (isSeller) return "Verkaeufer";
    if (isBuyer) return "Kaeufer";
    return "Konto";
  }

  function saveSession(session: Session) {
    writeJson(STORAGE_KEYS.session, session);
    renderAuthState();
  }

  function clearSession() {
    window.localStorage.removeItem(STORAGE_KEYS.session);
    renderAuthState();
  }

  async function handleDeleteAccount(button: HTMLButtonElement) {
    const session = readSession();
    if (!session) {
      window.location.href = "/anmelden/";
      return;
    }

    const confirmed = window.confirm(
      "Möchten Sie Ihr Konto wirklich endgültig löschen? Ihr Profil, Ihre Inserate, Favoriten, " +
      "Blockierungen und Benachrichtigungs-Einstellungen werden unwiderruflich entfernt. " +
      "Diese Aktion kann nicht rückgängig gemacht werden.",
    );
    if (!confirmed) return;

    const statusEl = document.querySelector<HTMLElement>("[data-delete-account-status]");
    const setStatus = (message: string, tone: "info" | "error") => {
      if (!statusEl) return;
      statusEl.textContent = message;
      statusEl.classList.remove("hidden", "text-muted-foreground", "text-error");
      statusEl.classList.add(tone === "error" ? "text-error" : "text-muted-foreground");
    };

    button.setAttribute("disabled", "true");
    setStatus("Konto wird gelöscht...", "info");

    try {
      // Die gesamte Loeschlogik liegt im Backend. Der Benutzer wird per Bearer-Token erkannt.
      await apiRequest("/api/auth/account", { method: "DELETE" });

      // Lokale Daten ebenfalls entfernen
      clearSession();
      window.localStorage.removeItem(STORAGE_KEYS.favorites);
      window.localStorage.removeItem(STORAGE_KEYS.blocked);
      window.localStorage.removeItem(STORAGE_KEYS.drafts);
      window.localStorage.removeItem(STORAGE_KEYS.notificationPreferences);
      window.localStorage.removeItem(STORAGE_KEYS.filterPreferences);

      window.alert("Ihr Konto und alle zugehörigen Daten wurden dauerhaft gelöscht.");
      window.location.href = "/";
    } catch (error) {
      button.removeAttribute("disabled");
      setStatus(
        error instanceof Error ? `Löschung fehlgeschlagen: ${error.message}` : "Löschung fehlgeschlagen.",
        "error",
      );
    }
  }

  async function apiRequest<TResponse>(path: string, options: RequestOptions = {}): Promise<TResponse> {
    const url = new URL(path, API_BASE_URL);
    const headers = new Headers(options.headers);

    if (options.body !== undefined && !headers.has("content-type")) {
      headers.set("content-type", "application/json");
    }

    const session = readSession();
    if (!options.skipAuth && session?.AccessToken && !headers.has("authorization")) {
      headers.set("authorization", `Bearer ${session.AccessToken}`);
    }

    const response = await fetch(url, {
      ...options,
      headers,
      body: options.body === undefined ? undefined : JSON.stringify(options.body),
    });

    const contentType = response.headers.get("content-type") ?? "";
    const payload = contentType.includes("application/json")
      ? await response.json()
      : await response.text();

    if (!response.ok) {
      throw new Error(typeof payload === "string" && payload ? payload : `Online-Anfrage fehlgeschlagen: ${response.status}`);
    }

    return payload as TResponse;
  }

  function toggleValue(key: string, value: string) {
    const values = new Set(readArray(key));
    const nextActive = !values.has(value);
    if (nextActive) {
      values.add(value);
    } else {
      values.delete(value);
    }
    writeArray(key, Array.from(values));
    return nextActive;
  }

  function removeValue(key: string, value: string) {
    const values = new Set(readArray(key));
    values.delete(value);
    writeArray(key, Array.from(values));
  }

  function setFormStatus(form: HTMLFormElement, message: string, tone: "info" | "error" | "success" = "info") {
    const status = form.querySelector<HTMLElement>("[data-form-status]");
    if (!status) return;

    status.textContent = message;
    status.classList.remove("hidden", "text-muted-foreground", "text-red-700", "text-green-700");
    if (tone === "error") status.classList.add("text-red-700");
    if (tone === "success") status.classList.add("text-green-700");
    if (tone === "info") status.classList.add("text-muted-foreground");
  }

  function renderAuthState() {
    const session = readSession();
    const loggedIn = !!session;
    const roles = readSessionRoles(session);
    const isBuyer = roles.has("buyer");
    const isSeller = roles.has("seller");

    document.querySelectorAll<HTMLElement>("[data-auth-email]").forEach((element) => {
      element.textContent = session?.Email ?? "";
    });
    document.querySelectorAll<HTMLElement>("[data-auth-name]").forEach((element) => {
      element.textContent = session?.FullName ?? "Nicht angemeldet";
    });
    document.querySelectorAll<HTMLElement>("[data-auth-initials]").forEach((element) => {
      element.textContent = loggedIn ? getInitials(session?.FullName) : "?";
    });
    document.querySelectorAll<HTMLElement>("[data-auth-role-badge]").forEach((element) => {
      element.textContent = loggedIn ? getRoleBadgeText(roles) : "";
    });
    document.querySelectorAll<HTMLElement>("[data-auth-user-id]").forEach((element) => {
      element.textContent = session?.UserId ?? "";
    });
    document.querySelectorAll<HTMLElement>("[data-auth-role-buyer]").forEach((element) => {
      element.hidden = !isBuyer;
    });
    document.querySelectorAll<HTMLElement>("[data-auth-role-seller]").forEach((element) => {
      element.hidden = !isSeller;
    });
    document.querySelectorAll<HTMLElement>("[data-guest-only]").forEach((element) => {
      element.hidden = loggedIn;
    });
    document.querySelectorAll<HTMLElement>("[data-auth-only]").forEach((element) => {
      element.hidden = !loggedIn;
    });
  }

  function bindRegisterRoleFields() {
    document.querySelectorAll<HTMLFormElement>("[data-auth-form='register']").forEach((form) => {
      const sellerRole = form.querySelector<HTMLInputElement>("[name='role'][value='seller']");
      const sellerFields = form.querySelector<HTMLElement>("[data-seller-fields]");
      const sellerTypes = Array.from(form.querySelectorAll<HTMLInputElement>("[name='sellerType']"));
      const brokerType = form.querySelector<HTMLInputElement>("[name='sellerType'][value='Broker']");
      const companyWrapper = form.querySelector<HTMLElement>("[data-company-field]");
      const companyName = form.querySelector<HTMLInputElement>("[name='companyName']");

      const update = () => {
        const sellerSelected = Boolean(sellerRole?.checked);
        if (sellerFields) sellerFields.hidden = !sellerSelected;
        sellerTypes.forEach((input) => {
          input.disabled = !sellerSelected;
        });

        const brokerSelected = sellerSelected && Boolean(brokerType?.checked);
        if (companyWrapper) companyWrapper.hidden = !brokerSelected;
        if (companyName) {
          companyName.disabled = !brokerSelected;
          companyName.required = brokerSelected;
          if (!brokerSelected) companyName.value = "";
        }
      };

      form.addEventListener("change", update);
      update();
    });
  }

  function validateRegisterForm(formData: FormData) {
    const password = String(formData.get("password") ?? "");
    const passwordConfirm = String(formData.get("passwordConfirm") ?? "");
    const roles = formData.getAll("role").map(String);
    const wantsSeller = roles.includes("seller");
    const sellerType = String(formData.get("sellerType") ?? "");
    const companyName = String(formData.get("companyName") ?? "").trim();

    if (password !== passwordConfirm) return "Die Passwoerter stimmen nicht ueberein.";
    if (roles.length === 0) return "Bitte mindestens eine Rolle auswaehlen.";
    if (wantsSeller && !sellerType) return "Bitte einen Anbietertyp auswaehlen.";
    if (wantsSeller && sellerType === "Broker" && !companyName) return "Bitte den Firmennamen angeben.";
    return "";
  }

  function bindAuthForms() {
    document.querySelectorAll<HTMLFormElement>("[data-auth-form]").forEach((form) => {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const mode = form.getAttribute("data-auth-form");
        const formData = new FormData(form);
        const submit = form.querySelector<HTMLButtonElement>("[type='submit']");
        const roles = formData.getAll("role").map((role) => role === "seller" ? "Seller" : "Buyer");
        const wantsSeller = roles.includes("Seller");
        const sellerType = wantsSeller ? String(formData.get("sellerType") ?? "Private") : "";
        const companyName = String(formData.get("companyName") ?? "").trim();

        if (mode === "register") {
          const validationMessage = validateRegisterForm(formData);
          if (validationMessage) {
            setFormStatus(form, validationMessage, "error");
            return;
          }
        }

        submit?.setAttribute("disabled", "true");
        setFormStatus(form, mode === "register" ? "Konto wird erstellt..." : "Anmeldung wird geprueft...");

        try {
          const payload = mode === "register"
            ? {
                Vorname: String(formData.get("firstName") ?? ""),
                Nachname: String(formData.get("lastName") ?? ""),
                Email: String(formData.get("email") ?? ""),
                Passwort: String(formData.get("password") ?? ""),
                Roles: roles,
                SellerType: wantsSeller ? sellerType : null,
                CompanyName: wantsSeller && sellerType === "Broker" ? companyName : null,
              }
            : {
                Email: String(formData.get("email") ?? ""),
                Passwort: String(formData.get("password") ?? ""),
              };

          const session = await apiRequest<Session>(
            mode === "register" ? "/api/auth/register" : "/api/auth/login",
            { method: "POST", body: payload, skipAuth: true },
          );

          saveSession(session);
          setFormStatus(form, "Erfolgreich angemeldet.", "success");
          const redirect = form.getAttribute("data-success-redirect") || "/profil/";
          window.location.href = redirect;
        } catch (error) {
          setFormStatus(
            form,
            error instanceof Error ? error.message : "Die Anmeldung ist fehlgeschlagen.",
            "error",
          );
        } finally {
          submit?.removeAttribute("disabled");
        }
      });
    });
  }

  function hasCheckbox(formData: FormData, name: string) {
    return formData.has(name);
  }

  function getStringArray(formData: FormData, name: string) {
    return formData.getAll(name).map((value) => String(value)).filter(Boolean);
  }

  function buildNotificationPreferences(formData: FormData) {
    return {
      IsEnabled: hasCheckbox(formData, "isEnabled"),
      FilterMode: String(formData.get("filterMode") ?? "SameAsSearch"),
      Locations: getStringArray(formData, "locations"),
      IsHausSelected: hasCheckbox(formData, "house"),
      IsGrundstueckSelected: hasCheckbox(formData, "land"),
      IsZwangsversteigerungSelected: hasCheckbox(formData, "foreclosure"),
      IsPrivateSelected: hasCheckbox(formData, "private"),
      IsBrokerSelected: hasCheckbox(formData, "broker"),
    };
  }

  function buildFilterPreferences(formData: FormData) {
    return {
      SelectedOrtes: getStringArray(formData, "locations"),
      SelectedAgeFilter: Number(formData.get("ageFilter") ?? 0),
      IsHausSelected: hasCheckbox(formData, "house"),
      IsGrundstueckSelected: hasCheckbox(formData, "land"),
      IsZwangsversteigerungSelected: hasCheckbox(formData, "foreclosure"),
      IsPrivateSelected: hasCheckbox(formData, "private"),
      IsBrokerSelected: hasCheckbox(formData, "broker"),
      ExcludedSellerSourceIds: [],
      SelectedSort: Number(formData.get("sort") ?? 0),
    };
  }

  function setCheckbox(form: HTMLFormElement, name: string, checked: boolean | undefined) {
    const input = form.querySelector<HTMLInputElement>(`input[type="checkbox"][name="${name}"]`);
    if (input && typeof checked === "boolean") input.checked = checked;
  }

  function setCheckboxValues(form: HTMLFormElement, name: string, values: unknown) {
    const selected = new Set(Array.isArray(values) ? values.map(String) : []);
    form.querySelectorAll<HTMLInputElement>(`input[type="checkbox"][name="${name}"]`).forEach((input) => {
      input.checked = selected.has(input.value);
    });
  }

  function normalizeAgeFilterValue(value: unknown) {
    const numeric = Number(value ?? 0);
    if (numeric === 7) return "2";
    if (numeric === 30) return "3";
    if (numeric >= 365) return "4";
    if ([0, 1, 2, 3, 4].includes(numeric)) return String(numeric);
    return "0";
  }

  function normalizeSortValue(value: unknown) {
    const numeric = Number(value ?? 0);
    return [0, 1, 2, 3, 4, 5, 6].includes(numeric) ? String(numeric) : "0";
  }

  function applySavedPreferences() {
    document.querySelectorAll<HTMLFormElement>("[data-preferences-form]").forEach((form) => {
      const mode = form.getAttribute("data-preferences-form");
      const preferences = mode === "notifications"
        ? readJson<Record<string, unknown>>(STORAGE_KEYS.notificationPreferences)
        : readJson<Record<string, unknown>>(STORAGE_KEYS.filterPreferences);
      if (!preferences) return;

      if (mode === "notifications") {
        setCheckbox(form, "isEnabled", preferences.IsEnabled as boolean);
        setCheckbox(form, "house", preferences.IsHausSelected as boolean);
        setCheckbox(form, "land", preferences.IsGrundstueckSelected as boolean);
        setCheckbox(form, "foreclosure", preferences.IsZwangsversteigerungSelected as boolean);
        setCheckbox(form, "private", preferences.IsPrivateSelected as boolean);
        setCheckbox(form, "broker", preferences.IsBrokerSelected as boolean);
        setCheckboxValues(form, "locations", preferences.Locations);
        const filterMode = form.querySelector<HTMLSelectElement>("[name='filterMode']");
        if (filterMode && typeof preferences.FilterMode === "string") filterMode.value = preferences.FilterMode;
      } else {
        setCheckbox(form, "house", preferences.IsHausSelected as boolean);
        setCheckbox(form, "land", preferences.IsGrundstueckSelected as boolean);
        setCheckbox(form, "foreclosure", preferences.IsZwangsversteigerungSelected as boolean);
        setCheckbox(form, "private", preferences.IsPrivateSelected as boolean);
        setCheckbox(form, "broker", preferences.IsBrokerSelected as boolean);
        const age = form.querySelector<HTMLSelectElement>("[name='ageFilter']");
        const sort = form.querySelector<HTMLSelectElement>("[name='sort']");
        const location = form.querySelector<HTMLSelectElement>("[name='locations']");
        if (age && preferences.SelectedAgeFilter !== undefined) age.value = normalizeAgeFilterValue(preferences.SelectedAgeFilter);
        if (sort && preferences.SelectedSort !== undefined) sort.value = normalizeSortValue(preferences.SelectedSort);
        setCheckboxValues(form, "locations", preferences.SelectedOrtes);
        if (location && Array.isArray(preferences.SelectedOrtes) && preferences.SelectedOrtes[0]) {
          location.value = String(preferences.SelectedOrtes[0]);
        }
      }
    });
  }

  function updateNotificationPreferenceVisibility(form: HTMLFormElement) {
    const enabled = form.querySelector<HTMLInputElement>("[name='isEnabled']")?.checked ?? true;
    const mode = form.querySelector<HTMLSelectElement>("[name='filterMode']")?.value ?? "SameAsSearch";
    const showFilters = enabled;
    const showCustom = enabled && mode === "Custom";

    form.querySelectorAll<HTMLElement>("[data-notification-filter-settings]").forEach((element) => {
      element.hidden = !showFilters;
    });
    form.querySelectorAll<HTMLElement>("[data-notification-custom]").forEach((element) => {
      element.hidden = !showCustom;
    });
  }

  function bindNotificationPreferenceVisibility() {
    document.querySelectorAll<HTMLFormElement>("[data-preferences-form='notifications']").forEach((form) => {
      form.addEventListener("change", () => updateNotificationPreferenceVisibility(form));
      updateNotificationPreferenceVisibility(form);
    });
  }

  function bindPreferenceForms() {
    document.querySelectorAll<HTMLFormElement>("[data-preferences-form]").forEach((form) => {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const mode = form.getAttribute("data-preferences-form");
        const submit = form.querySelector<HTMLButtonElement>("[type='submit']");
        const formData = new FormData(form);
        const preferences = mode === "notifications"
          ? buildNotificationPreferences(formData)
          : buildFilterPreferences(formData);

        const storageKey = mode === "notifications"
          ? STORAGE_KEYS.notificationPreferences
          : STORAGE_KEYS.filterPreferences;
        const endpoint = mode === "notifications"
          ? "/api/notifications/preferences"
          : "/api/auth/filter-preferences";
        const method = mode === "notifications" ? "PUT" : "POST";

        writeJson(storageKey, preferences);
        submit?.setAttribute("disabled", "true");
        setFormStatus(form, readSession() ? "Einstellungen werden synchronisiert..." : "Einstellungen lokal gespeichert.");

        try {
          if (readSession()) {
            await apiRequest(endpoint, { method, body: preferences });
            setFormStatus(form, "Einstellungen gespeichert und synchronisiert.", "success");
          } else {
            setFormStatus(form, "Einstellungen lokal gespeichert. Nach dem Login werden sie synchronisiert.", "success");
          }
        } catch (error) {
          setFormStatus(
            form,
            error instanceof Error
              ? `Lokal gespeichert, Online-Sync fehlgeschlagen: ${error.message}`
              : "Lokal gespeichert, Online-Sync fehlgeschlagen.",
            "error",
          );
        } finally {
          submit?.removeAttribute("disabled");
        }
      });
    });
  }

  function refreshActionButtons() {
    const favorites = new Set(readArray(STORAGE_KEYS.favorites));
    const blocked = new Set(readArray(STORAGE_KEYS.blocked));

    document.querySelectorAll("[data-property-action]").forEach((button) => {
      const action = button.getAttribute("data-property-action");
      const slug = button.getAttribute("data-property-slug");
      if (!slug || !(button instanceof HTMLButtonElement)) return;

      const active = action === "favorite" ? favorites.has(slug) : blocked.has(slug);
      button.setAttribute("aria-pressed", String(active));
      if (action === "favorite") {
        button.setAttribute("aria-label", active ? "Favorit entfernen" : "Favorit speichern");
      }
      if (action === "block") {
        button.setAttribute("aria-label", active ? "Blockierung entfernen" : "Immobilie blockieren");
      }

      const label = button.querySelector<HTMLElement>("[data-action-label]");
      if (label) {
        label.textContent = active
          ? button.getAttribute("data-active-text") ?? label.textContent
          : button.getAttribute("data-inactive-text") ?? label.textContent;
      }
    });
  }

  function closeCardMenus(except?: HTMLElement | null) {
    document.querySelectorAll<HTMLElement>("[data-card-menu]").forEach((menu) => {
      if (menu === except) return;
      menu.classList.add("hidden");
      const button = document.querySelector<HTMLButtonElement>(`[data-card-action][aria-controls="${menu.id}"]`);
      button?.setAttribute("aria-expanded", "false");
    });
  }

  async function syncRemotePropertyAction(action: string | null, propertyId: string | null, active: boolean) {
    const session = readSession();
    if (!session || !propertyId || !UUID_PATTERN.test(propertyId)) return;

    try {
      if (action === "favorite") {
        await apiRequest(
          active ? "/api/favorites" : `/api/favorites/${propertyId}`,
          active ? { method: "POST", body: { PropertyId: propertyId } } : { method: "DELETE" },
        );
      }

      if (action === "block") {
        await apiRequest(
          active ? "/api/blocked" : `/api/blocked/${propertyId}`,
          active ? { method: "POST", body: { PropertyId: propertyId } } : { method: "DELETE" },
        );
      }
    } catch (error) {
      console.warn("[Heimatplatz] API sync for property status failed", error);
    }
  }

  function syncUserLists() {
    const favorites = new Set(readArray(STORAGE_KEYS.favorites));
    const blocked = new Set(readArray(STORAGE_KEYS.blocked));

    document.querySelectorAll("[data-user-list]").forEach((list) => {
      const mode = list.getAttribute("data-user-mode");
      if (mode !== "favorites" && mode !== "blocked") return;

      const wanted = mode === "favorites" ? favorites : blocked;
      let visible = 0;
      list.querySelectorAll<HTMLElement>("[data-property-card]").forEach((card) => {
        const slug = card.getAttribute("data-slug");
        const show = !!slug && wanted.has(slug);
        card.hidden = !show;
        if (show) visible += 1;
      });

      list.classList.toggle("hidden", visible === 0);
      const empty = list.closest("[data-user-page]")?.querySelector("[data-user-empty]");
      empty?.classList.toggle("hidden", visible > 0);
    });
  }

  function formatEuro(value: string | undefined) {
    const number = Number(value);
    if (!Number.isFinite(number) || number <= 0) return "Preis offen";
    return new Intl.NumberFormat("de-AT", {
      style: "currency",
      currency: "EUR",
      maximumFractionDigits: 0,
    }).format(number);
  }

  function formatPriceValue(value: number | string | undefined) {
    const number = Number(value);
    if (!Number.isFinite(number) || number <= 0) return "Preis offen";
    if (number >= 1_000_000) return `${(number / 1_000_000).toLocaleString("de-AT", { maximumFractionDigits: 1 })} Mio. EUR`;
    if (number >= 1000) return `${Math.round(number / 1000).toLocaleString("de-AT")} Tsd. EUR`;
    return `${number.toLocaleString("de-AT")} EUR`;
  }

  function createText<K extends keyof HTMLElementTagNameMap>(tag: K, className: string, text: string) {
    const element = document.createElement(tag);
    element.className = className;
    element.textContent = text;
    return element;
  }

  function getImageState(form: HTMLFormElement) {
    let state = imageFormState.get(form);
    if (!state) {
      state = [];
      imageFormState.set(form, state);
    }
    return state;
  }

  function getDraftImageUrls(draft: Draft) {
    return Array.isArray(draft.imageUrls) ? draft.imageUrls.filter(Boolean) : [];
  }

  function writeImageUrlField(form: HTMLFormElement) {
    const field = form.querySelector<HTMLInputElement>("[data-property-image-urls]");
    if (!field) return;
    field.value = JSON.stringify(getImageState(form).map((item) => item.url));
  }

  function renderImageGrid(form: HTMLFormElement) {
    const state = getImageState(form);
    const grid = form.querySelector<HTMLElement>("[data-property-image-grid]");
    const count = form.querySelector<HTMLElement>("[data-property-image-count]");
    if (count) count.textContent = `Fotos ${state.length} / ${MAX_PROPERTY_IMAGES}`;
    if (!grid) return;

    grid.textContent = "";
    grid.classList.toggle("hidden", state.length === 0);
    state.forEach((item) => {
      const frame = document.createElement("div");
      frame.className = "relative aspect-[4/3] overflow-hidden rounded-md border border-border bg-muted";

      const image = document.createElement("img");
      image.src = item.url;
      image.alt = item.fileName;
      image.className = "h-full w-full object-cover";
      image.loading = "lazy";
      image.addEventListener("error", () => {
        image.src = "/og/heimatplatz-default.svg";
      }, { once: true });

      const remove = document.createElement("button");
      remove.type = "button";
      remove.className = "absolute right-1 top-1 grid size-7 place-items-center rounded-full bg-black/70 text-xs font-bold text-white";
      remove.setAttribute("aria-label", "Foto entfernen");
      remove.textContent = "x";
      remove.addEventListener("click", () => {
        imageFormState.set(form, getImageState(form).filter((entry) => entry.id !== item.id));
        writeImageUrlField(form);
        renderImageGrid(form);
      });

      frame.append(image, remove);
      grid.append(frame);
    });

    writeImageUrlField(form);
  }

  function setFormImages(form: HTMLFormElement, urls: string[]) {
    imageFormState.set(
      form,
      urls.slice(0, MAX_PROPERTY_IMAGES).map((url, index) => ({
        id: `existing-${index}-${url}`,
        url,
        fileName: url.split("/").pop() || `Bild ${index + 1}`,
        contentType: url.startsWith("data:") ? (url.match(/^data:([^;]+);/)?.[1] ?? "image/jpeg") : "image/jpeg",
        existing: !url.startsWith("data:"),
      })),
    );
    renderImageGrid(form);
  }

  function readFileAsDataUrl(file: File) {
    return new Promise<string>((resolve, reject) => {
      const reader = new FileReader();
      reader.addEventListener("load", () => resolve(String(reader.result ?? "")));
      reader.addEventListener("error", () => reject(reader.error ?? new Error("Datei konnte nicht gelesen werden.")));
      reader.readAsDataURL(file);
    });
  }

  async function getLocalImageUrls(form: HTMLFormElement) {
    const urls: string[] = [];
    for (const item of getImageState(form)) {
      if (!item.file) {
        urls.push(item.url);
      } else {
        urls.push(await readFileAsDataUrl(item.file));
      }
    }
    return urls;
  }

  async function uploadImages(form: HTMLFormElement, requireImage: boolean) {
    const state = getImageState(form);
    if (requireImage && state.length === 0) {
      throw new Error("Bitte fuegen Sie mindestens ein Foto hinzu.");
    }

    const existingUrls = state.filter((item) => item.existing && item.url).map((item) => item.url);
    const newImages = state.filter((item) => item.file || (!item.existing && item.url.startsWith("data:")));
    if (newImages.length === 0) return existingUrls;

    const images = await Promise.all(newImages.map(async (item) => {
      const dataUrl = item.file ? await readFileAsDataUrl(item.file) : item.url;
      return {
        FileName: item.fileName,
        ContentType: item.contentType || item.file?.type || dataUrl.match(/^data:([^;]+);/)?.[1] || "image/jpeg",
        Base64Data: dataUrl.split(",")[1] ?? "",
      };
    }));

    const response = await apiRequest<{ ImageUrls: string[] }>("/api/properties/images", {
      method: "POST",
      body: { Images: images },
    });

    return [...existingUrls, ...(response.ImageUrls ?? [])];
  }

  function bindImagePickers() {
    document.querySelectorAll<HTMLFormElement>("[data-local-property-form]").forEach((form) => {
      renderImageGrid(form);
      const input = form.querySelector<HTMLInputElement>("[data-property-images]");
      if (!input) return;

      input.addEventListener("change", () => {
        const files = Array.from(input.files ?? []);
        if (files.length === 0) return;

        const state = getImageState(form);
        const remaining = Math.max(0, MAX_PROPERTY_IMAGES - state.length);
        files.slice(0, remaining).forEach((file) => {
          state.push({
            id: `${Date.now()}-${crypto.randomUUID?.() ?? Math.random().toString(36).slice(2)}`,
            url: URL.createObjectURL(file),
            fileName: file.name,
            contentType: file.type || "image/jpeg",
            existing: false,
            file,
          });
        });

        input.value = "";
        renderImageGrid(form);
        if (files.length > remaining) {
          setFormStatus(form, `Nur ${remaining} weitere Bilder konnten hinzugefuegt werden.`, "error");
        }
      });
    });
  }

  function createDraftCard(draft: Draft) {
