    card.className = "rounded-lg border border-border bg-card p-4 shadow-sm";
    const imageUrls = getDraftImageUrls(draft);

    if (imageUrls[0]) {
      const image = document.createElement("img");
      image.src = imageUrls[0];
      image.alt = draft.title || "Immobilienfoto";
      image.className = "mb-4 aspect-[4/3] w-full rounded-md object-cover";
      image.loading = "lazy";
      image.addEventListener("error", () => {
        image.remove();
      }, { once: true });
      card.append(image);
    }

    const eyebrow = createText("p", "text-xs font-semibold uppercase text-muted-foreground", "Lokaler Entwurf");
