---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PropertySearchApp from "@/components/properties/PropertySearchApp.astro";
import { guidePages } from "@/data/guide-pages";
import { getLocalityPath, getRegionLocalities } from "@/data/locality-search-pages";
import { searchIntents, type SearchIntent } from "@/data/search-intents";
import { upperAustriaRegions } from "@/data/upper-austria-regions";
import type { PropertyEntry } from "@/features/properties/format";
import {
  API_PROPERTY_BUILD_LIMIT,
  fetchApiProperties,
  getApiPropertyPath,
  getApiPropertyTypeSearchValue,
  getApiSellerSearchValue,
} from "@/features/properties/live-api";
import { breadcrumbSchema, faqSchema } from "@/lib/seo";

interface Props {
  intent: SearchIntent;
  properties: PropertyEntry[];
}

const { intent, properties } = Astro.props;
const relatedRegions = upperAustriaRegions.filter((region) => intent.relatedRegionSlugs.includes(region.slug));
const relatedLocalities = relatedRegions.flatMap((region) => getRegionLocalities(region.slug, 3)).slice(0, 12);
const relatedIntents = searchIntents.filter((item) => item.slug !== intent.slug).slice(0, 4);
const relatedGuides = guidePages.filter((guide) => guide.relatedIntentSlugs.includes(intent.slug)).slice(0, 3);
const faqItems = [
  {
    question: `Welche Angebote zeigt Heimatplatz fuer ${intent.title}?`,
    answer: `${intent.description} Die Seite verbindet indexierbare Objektseiten mit aktuellen Live-Angeboten aus Oberösterreich.`,
  },
  {
    question: `Wie grenze ich ${intent.h1} regional ein?`,
    answer:
      "Nutze Suchbegriff, Bezirksauswahl, Zeitraum, Immobilientyp und Anbieterfilter oder oeffne direkt die verlinkten Bezirks- und Ortsseiten.",
  },
  {
    question: "Sind private Angebote, Maklerangebote und Portale getrennt filterbar?",
    answer:
      "Ja. Die Suche unterscheidet Privat, Makler und Portal beziehungsweise gerichtliche Quellen, damit passende Angebote schneller vergleichbar sind.",
  },
  {
    question: "Warum sind regionale Landingpages fuer die Suche hilfreich?",
    answer:
      "Regionale Seiten buendeln Orte, Bezirke, Objekttypen und Detailseiten, wodurch Nutzer und Suchmaschinen schneller relevante Immobilien in Oberösterreich finden.",
  },
];
const apiProperties = (await fetchApiProperties({
  pageSize: API_PROPERTY_BUILD_LIMIT,
  propertyTypes: intent.presetType
    ? [intent.presetType === "land" ? "Land" : intent.presetType === "foreclosure" ? "Foreclosure" : "House"]
    : undefined,
})).filter((property) => {
  const typeMatches = !intent.presetType || getApiPropertyTypeSearchValue(property.Type, property) === intent.presetType;
  const sellerMatches = !intent.presetSeller || getApiSellerSearchValue(property.SellerType) === intent.presetSeller;
  return typeMatches && sellerMatches;
});
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: intent.h1,
  description: intent.description,
  keywords: intent.keywords,
  mainEntity: {
    "@type": "ItemList",
    itemListElement: [
      ...properties.map((property, index) => ({
        "@type": "ListItem",
        position: index + 1,
        url: new URL(`/immobilien/${property.data.slug}/`, Astro.site).toString(),
        name: property.data.title,
      })),
      ...apiProperties.map((property, index) => ({
        "@type": "ListItem",
        position: properties.length + index + 1,
        url: new URL(getApiPropertyPath(property), Astro.site).toString(),
        name: property.Title,
      })),
    ],
  },
};
---

<BaseLayout
  title={intent.title}
  description={intent.description}
  canonicalPath={intent.canonicalPath}
  structuredData={[
    breadcrumbSchema([
      { name: "Heimatplatz", url: new URL("/", Astro.site).toString() },
      { name: "Immobilien", url: new URL("/immobilien/", Astro.site).toString() },
      { name: intent.title, url: new URL(intent.canonicalPath, Astro.site).toString() },
    ]),
    itemListSchema,
    faqSchema(faqItems),
  ]}
>
  <PropertySearchApp
    properties={properties}
    apiProperties={apiProperties}
    introTitle={intent.h1}
    introDescription={intent.description}
    showIntro
    presetType={intent.presetType ?? ""}
    presetSeller={intent.presetSeller ?? ""}
  />

  <section class="border-t border-border bg-muted/25">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 py-10 sm:px-6 lg:grid-cols-[1fr_320px] lg:px-8">
      <div>
        <h2 class="text-2xl font-bold">Marktüberblick für {intent.title}</h2>
        <ul class="mt-5 grid gap-3 text-sm leading-6 text-muted-foreground">
          {intent.marketNotes.map((note) => <li class="rounded-lg border border-border bg-card p-4">{note}</li>)}
        </ul>

        <h2 class="mt-8 text-xl font-bold">Wichtige Regionen</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          {relatedRegions.map((region) => (
            <a class="rounded-lg border border-border bg-card p-4 hover:border-foreground" href={`/immobilien/oberoesterreich/${region.slug}/`}>
              <span class="text-sm font-semibold">{region.name}</span>
              <p class="mt-2 text-sm leading-6 text-muted-foreground">{region.description}</p>
            </a>
          ))}
        </div>

        <h2 class="mt-8 text-xl font-bold">Wichtige Orte</h2>
        <div class="mt-4 flex flex-wrap gap-2">
          {relatedLocalities.map((locality) => (
            <a class="rounded-full border border-border bg-card px-3 py-1.5 text-sm font-medium hover:border-foreground" href={getLocalityPath(locality.slug)}>
              {intent.h1.replace("in Oberösterreich", `in ${locality.name}`)}
            </a>
          ))}
        </div>

        <section class="mt-8" aria-labelledby="intent-faq">
          <h2 id="intent-faq" class="text-xl font-bold">Haeufige Fragen</h2>
          <div class="mt-4 grid gap-3">
            {faqItems.map((item) => (
              <details class="rounded-lg border border-border bg-card p-4">
                <summary class="cursor-pointer text-sm font-semibold">{item.question}</summary>
                <p class="mt-3 text-sm leading-6 text-muted-foreground">{item.answer}</p>
              </details>
            ))}
          </div>
        </section>
      </div>

      <aside class="self-start rounded-lg border border-border bg-card p-5">
        <h2 class="text-lg font-bold">Weitere Suchen</h2>
        <ul class="mt-4 space-y-3 text-sm text-muted-foreground">
          {relatedIntents.map((item) => (
            <li><a class="hover:text-foreground" href={item.canonicalPath}>{item.title}</a></li>
          ))}
          {relatedGuides.map((guide) => (
            <li><a class="hover:text-foreground" href={guide.canonicalPath}>{guide.h1}</a></li>
          ))}
          <li><a class="hover:text-foreground" href="/immobilien/oberoesterreich/">Alle Bezirke in Oberösterreich</a></li>
          <li><a class="hover:text-foreground" href="/zwangsversteigerungen/">Zwangsversteigerungen Oberösterreich</a></li>
        </ul>
      </aside>
    </div>
  </section>
</BaseLayout>
