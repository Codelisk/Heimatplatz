---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeartIcon from "@tabler/icons/outline/heart.svg";
import EyeOffIcon from "@tabler/icons/outline/eye-off.svg";
import HomeIcon from "@tabler/icons/outline/home.svg";

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  emptyTitle?: string;
  emptyText?: string;
  mode?: "favorites" | "blocked" | "mine";
}

const {
  title,
  description,
  canonicalPath,
  emptyTitle,
  emptyText,
  mode = "favorites",
} = Astro.props;

const emptyDefaults = {
  favorites: {
    title: "Noch keine Favoriten",
    text: "Markieren Sie Immobilien als Favoriten, um sie hier zu sehen.",
    Icon: HeartIcon,
  },
  blocked: {
    title: "Keine blockierten Immobilien",
    text: "Blockierte Immobilien werden hier angezeigt und in der Suche ausgeblendet.",
    Icon: EyeOffIcon,
  },
  mine: {
    title: "Noch keine eigenen Inserate",
    text: "Inserieren Sie Ihre erste Immobilie ueber das Menue.",
    Icon: HomeIcon,
  },
} as const;

const empty = emptyDefaults[mode];
const Icon = empty.Icon;
const isMine = mode === "mine";
const savedDraft = isMine && Astro.url.searchParams.has("gespeichert");
const editedDraft = isMine && Astro.url.searchParams.has("bearbeitet");
const statusMessage = editedDraft ? "Aenderungen gespeichert." : "Entwurf gespeichert.";
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} noindex>
  <section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8" data-user-page>
    {isMine && (
      <div class:list={["mb-5 rounded-md border border-border bg-muted px-4 py-3 text-sm font-medium", !(savedDraft || editedDraft) && "hidden"]} data-mine-status>
        <span data-mine-status-text>{statusMessage}</span>
      </div>
    )}

    <div class="hidden grid gap-4 sm:grid-cols-2 xl:grid-cols-3" data-remote-properties data-remote-mode={mode}></div>
    {isMine && <div class="hidden grid gap-4 sm:grid-cols-2 xl:grid-cols-3" data-local-drafts></div>}

    <div class="flex min-h-[60vh] flex-col items-center justify-center gap-3 text-center" data-user-empty>
      <Icon class="size-16 text-muted-foreground" aria-hidden="true" />
      <h2 class="text-lg font-semibold">{emptyTitle ?? empty.title}</h2>
      <p class="max-w-sm text-sm text-muted-foreground">{emptyText ?? empty.text}</p>
    </div>
  </section>
</BaseLayout>
