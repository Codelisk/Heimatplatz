---
import CalendarIcon from "@tabler/icons/outline/calendar.svg";
import EyeOffIcon from "@tabler/icons/outline/eye-off.svg";
import FileTextIcon from "@tabler/icons/outline/file-text.svg";
import HeartIcon from "@tabler/icons/outline/heart.svg";
import MapPinIcon from "@tabler/icons/outline/map-pin.svg";
import ScaleIcon from "@tabler/icons/outline/scale.svg";
import {
  formatAuctionArea,
  formatAuctionDateShort,
  getAuctionPriceLabel,
  getAuctionPrimaryArea,
  getAuctionTitle,
  getForeclosureAuctionPath,
  getForeclosureCategoryLabel,
  type ApiForeclosureAuction,
} from "@/features/foreclosures/api";

interface Props {
  auction: ApiForeclosureAuction;
}

const { auction } = Astro.props;
const href = getForeclosureAuctionPath(auction);
const area = formatAuctionArea(getAuctionPrimaryArea(auction), "Fläche offen");
---

<article
  class="overflow-hidden rounded-lg border border-border bg-card shadow-sm"
  data-property-card
  data-slug={auction.Id}
  data-property-id={auction.Id}
>
  <a href={href} class="block p-4 hover:bg-muted/35">
    <div class="flex items-start justify-between gap-3">
      <span class="rounded-full bg-foreground px-3 py-1 text-xs font-bold text-background">ZV</span>
      <span class="text-right text-sm font-semibold text-muted-foreground">{getAuctionPriceLabel(auction)}</span>
    </div>

    <h2 class="mt-4 text-lg font-bold leading-snug">{getAuctionTitle(auction)}</h2>
    <p class="mt-2 line-clamp-3 text-sm leading-6 text-muted-foreground">{auction.ObjectDescription}</p>

    <p class="mt-3 flex items-center gap-2 text-sm text-muted-foreground">
      <MapPinIcon class="size-4 shrink-0" aria-hidden="true" />
      <span class="truncate">{auction.PostalCode} {auction.City}</span>
    </p>

    <dl class="mt-4 grid grid-cols-2 gap-2 text-sm">
      <div class="rounded-md bg-muted px-3 py-2">
        <dt class="flex items-center gap-1 text-xs text-muted-foreground">
          <CalendarIcon class="size-3" aria-hidden="true" />
          Termin
        </dt>
        <dd class="mt-1 font-semibold">{formatAuctionDateShort(auction.AuctionDate)}</dd>
      </div>
      <div class="rounded-md bg-muted px-3 py-2">
        <dt class="flex items-center gap-1 text-xs text-muted-foreground">
          <ScaleIcon class="size-3" aria-hidden="true" />
          Fläche
        </dt>
        <dd class="mt-1 font-semibold">{area}</dd>
      </div>
    </dl>

    <div class="mt-4 flex items-center justify-between gap-3 border-t border-border pt-3 text-xs text-muted-foreground">
      <span class="truncate">{getForeclosureCategoryLabel(auction.Category)}</span>
      {auction.Court && (
        <span class="flex min-w-0 items-center gap-1">
          <FileTextIcon class="size-3 shrink-0" aria-hidden="true" />
          <span class="truncate">{auction.Court}</span>
        </span>
      )}
    </div>
  </a>
  <div class="grid grid-cols-2 gap-2 border-t border-border p-3">
    <button
      class="inline-flex h-9 items-center justify-center gap-2 rounded-md border border-border px-3 text-xs font-semibold hover:border-foreground"
      type="button"
      aria-label="Zwangsversteigerung merken"
      aria-pressed="false"
      data-property-action="favorite"
      data-property-slug={auction.Id}
      data-property-id={auction.Id}
    >
      <HeartIcon class="size-3.5" aria-hidden="true" />
      Merken
    </button>
    <button
      class="inline-flex h-9 items-center justify-center gap-2 rounded-md border border-border px-3 text-xs font-semibold hover:border-foreground"
      type="button"
      aria-label="Zwangsversteigerung blockieren"
      aria-pressed="false"
      data-property-action="block"
      data-property-slug={auction.Id}
      data-property-id={auction.Id}
    >
      <EyeOffIcon class="size-3.5" aria-hidden="true" />
      Blockieren
    </button>
  </div>
</article>
