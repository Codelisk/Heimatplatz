---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ForeclosureAuctionCard from "@/components/foreclosures/ForeclosureAuctionCard.astro";
import {
  fetchForeclosureAuctions,
  getAuctionPriceLabel,
  getForeclosureAuctionPath,
} from "@/features/foreclosures/api";
import { breadcrumbSchema } from "@/lib/seo";

const auctions = await fetchForeclosureAuctions();
const cities = [...new Set(auctions.map((auction) => auction.City).filter(Boolean))].sort((a, b) =>
  a.localeCompare(b, "de-AT"),
);
const pricedAuctions = auctions.filter((auction) => getAuctionPriceLabel(auction) !== "Preis offen").length;
const courts = [...new Set(auctions.map((auction) => auction.Court).filter(Boolean))].length;
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Zwangsversteigerungen Oberösterreich",
  description: "Aktuelle gerichtliche Immobilienversteigerungen in Oberösterreich.",
  mainEntity: {
    "@type": "ItemList",
    itemListElement: auctions.map((auction, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: new URL(getForeclosureAuctionPath(auction), Astro.site).toString(),
      name: `${auction.ObjectDescription} in ${auction.PostalCode} ${auction.City}`,
    })),
  },
};
---

<BaseLayout
  title="Zwangsversteigerungen Oberösterreich"
  description="Aktuelle Zwangsversteigerungen in Oberösterreich finden: Versteigerungstermine, Schätzwerte, Mindestgebote, Bezirksgerichte und Edikte."
  canonicalPath="/zwangsversteigerungen/"
  structuredData={[
    breadcrumbSchema([
      { name: "Heimatplatz", url: new URL("/", Astro.site).toString() },
      { name: "Zwangsversteigerungen", url: new URL("/zwangsversteigerungen/", Astro.site).toString() },
    ]),
    itemListSchema,
  ]}
>
  <section class="border-b border-border bg-muted/35">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
      <p class="text-sm font-bold uppercase text-muted-foreground">Gerichtliche Immobilien</p>
      <h1 class="mt-3 max-w-4xl text-3xl font-bold leading-tight sm:text-4xl">
        Zwangsversteigerungen in Oberösterreich
      </h1>
      <p class="mt-4 max-w-3xl text-base leading-7 text-muted-foreground">
        Versteigerungsobjekte aus Oberösterreich mit Ort, Gericht, Termin, Schätzwert,
        Mindestgebot und Edikt-Link an einem Platz.
      </p>

      <dl class="mt-6 grid gap-3 sm:grid-cols-3">
        <div class="rounded-lg border border-border bg-card p-4">
          <dt class="text-sm text-muted-foreground">Aktuelle Einträge</dt>
          <dd class="mt-1 text-3xl font-bold">{auctions.length}</dd>
        </div>
        <div class="rounded-lg border border-border bg-card p-4">
          <dt class="text-sm text-muted-foreground">Orte</dt>
          <dd class="mt-1 text-3xl font-bold">{cities.length}</dd>
        </div>
        <div class="rounded-lg border border-border bg-card p-4">
          <dt class="text-sm text-muted-foreground">Mit Preisangabe</dt>
          <dd class="mt-1 text-3xl font-bold">{pricedAuctions}</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-[260px_minmax(0,1fr)]">
      <aside class="self-start rounded-lg border border-border bg-card p-5 lg:sticky lg:top-20">
        <h2 class="text-sm font-bold uppercase text-muted-foreground">Schnellüberblick</h2>
        <dl class="mt-4 space-y-3 text-sm">
          <div>
            <dt class="text-muted-foreground">Bezirksgerichte</dt>
            <dd class="font-semibold">{courts || "Nicht angegeben"}</dd>
          </div>
          <div>
            <dt class="text-muted-foreground">Region</dt>
            <dd class="font-semibold">Oberösterreich</dd>
          </div>
          <div>
            <dt class="text-muted-foreground">Quelle</dt>
            <dd class="font-semibold">Edikte / Gerichtsdaten</dd>
          </div>
        </dl>

        {cities.length > 0 && (
          <div class="mt-6 border-t border-border pt-4">
            <h3 class="text-sm font-semibold">Orte</h3>
            <div class="mt-3 flex flex-wrap gap-2">
              {cities.slice(0, 16).map((city) => (
                <span class="rounded-md bg-muted px-2.5 py-1 text-xs font-medium">{city}</span>
              ))}
            </div>
          </div>
        )}
      </aside>

      <div>
        {auctions.length > 0 ? (
          <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
            {auctions.map((auction) => <ForeclosureAuctionCard auction={auction} />)}
          </div>
        ) : (
          <div class="rounded-lg border border-border bg-card p-8">
            <h2 class="text-2xl font-bold">Keine aktuellen Zwangsversteigerungen gefunden</h2>
            <p class="mt-3 text-sm leading-6 text-muted-foreground">
              Sobald neue gerichtliche Immobilienversteigerungen in Oberösterreich vorliegen,
              erscheinen sie hier mit Detailseite und Edikt-Verweis.
            </p>
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-muted/25">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold">Immobilien und Versteigerungen gemeinsam durchsuchen</h2>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-muted-foreground">
        Für Hauskauf, Grundstücke und klassische Immobilienangebote in Oberösterreich ist die
        regionale Suche der schnellste Einstieg.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a class="inline-flex h-10 items-center rounded-md bg-foreground px-4 text-sm font-semibold text-background" href="/immobilien/?type=foreclosure">
          ZV in der Immobiliensuche
        </a>
        <a class="inline-flex h-10 items-center rounded-md border border-border px-4 text-sm font-semibold" href="/immobilien/oberoesterreich/">
          Bezirke in Oberösterreich
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
