---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PhotoPlusIcon from "@tabler/icons/outline/photo-plus.svg";
import { Button } from "@/components/starwind/button";
import { Input } from "@/components/starwind/input";
import { Label } from "@/components/starwind/label";
import { NativeSelect } from "@/components/starwind/native-select";
import { Textarea } from "@/components/starwind/textarea";
---

<BaseLayout
  title="Immobilie in Oberösterreich inserieren"
  description="Immobilie in Oberösterreich inserieren: Haus, Wohnung oder Grundstueck mit Fotos, Adresse, Preis und Kontaktdaten vorbereiten."
  canonicalPath="/inserieren/"
>
  <section class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
    <form class="space-y-5" action="/meine-immobilien/" method="get" data-local-property-form>
      <input type="hidden" name="municipalityId" />
      <input type="hidden" name="imageUrls" data-property-image-urls />
      <div class="max-w-xs space-y-2">
        <Label for="propertyType">Immobilientyp *</Label>
        <NativeSelect id="propertyType" name="propertyType" required>
          <option value="house">Haus</option>
          <option value="apartment">Wohnung</option>
          <option value="land">Grundstueck</option>
          <option value="foreclosure">Zwangsversteigerung</option>
        </NativeSelect>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        <div class="space-y-2">
          <Label for="sellerName">Anbietername *</Label>
          <Input id="sellerName" name="sellerName" placeholder="z.B. Max Mustermann" required />
        </div>
        <div class="space-y-2">
          <Label for="sellerType">Anbietertyp *</Label>
          <NativeSelect id="sellerType" name="sellerType" required>
            <option value="Private">Privat</option>
            <option value="Broker">Makler</option>
          </NativeSelect>
        </div>
      </div>
      <div class="space-y-2">
        <Label for="title">Titel *</Label>
        <Input id="title" name="title" placeholder="z.B. Schoene 3-Zimmer Wohnung in Linz" minlength="10" required />
      </div>
      <div class="space-y-2">
        <Label for="description">Beschreibung *</Label>
        <Textarea id="description" name="description" placeholder="Detaillierte Beschreibung mit Lage, Zustand und Besonderheiten (mind. 50 Zeichen)" class="min-h-28" minlength="50" required />
      </div>
      <div class="space-y-2">
        <Label for="municipalityLookup">Ort auswaehlen *</Label>
        <NativeSelect id="municipalityLookup" name="municipalityLookup" data-location-select>
          <option value="">Orte werden geladen...</option>
        </NativeSelect>
        <p class="text-xs text-muted-foreground" data-location-status>Gemeinden in Oberösterreich werden geladen.</p>
      </div>
      <div class="grid gap-4 md:grid-cols-[1fr_1fr_120px]">
        <div class="space-y-2">
          <Label for="address">Adresse *</Label>
          <Input id="address" name="address" placeholder="Strasse und Hausnummer" required />
        </div>
        <div class="space-y-2">
          <Label for="city">Ort *</Label>
          <Input id="city" name="city" placeholder="z.B. Linz" required />
        </div>
        <div class="space-y-2">
          <Label for="postalCode">PLZ *</Label>
          <Input id="postalCode" name="postalCode" inputmode="numeric" minlength="4" maxlength="4" pattern="[0-9]{4}" placeholder="4020" required />
        </div>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        <div class="space-y-2">
          <Label for="price">Preis (EUR) *</Label>
          <Input id="price" name="price" type="number" inputmode="numeric" min="1" step="1" placeholder="350000" required />
        </div>
        <div class="space-y-2" data-structure-property-field>
          <Label for="livingArea">Wohnflaeche (m2)</Label>
          <Input id="livingArea" name="livingArea" type="number" inputmode="numeric" min="1" step="1" placeholder="90" />
        </div>
        <div class="space-y-2">
          <Label for="plotArea">Grundstuecksflaeche (m2)</Label>
          <Input id="plotArea" name="plotArea" type="number" inputmode="numeric" min="1" step="1" placeholder="500" />
        </div>
        <div class="space-y-2" data-structure-property-field>
          <Label for="rooms">Zimmer</Label>
          <Input id="rooms" name="rooms" type="number" inputmode="numeric" min="1" step="1" placeholder="3" />
        </div>
        <div class="space-y-2" data-structure-property-field>
          <Label for="yearBuilt">Baujahr</Label>
          <Input id="yearBuilt" name="yearBuilt" type="number" inputmode="numeric" min="1000" step="1" placeholder="1998" />
        </div>
      </div>
      <fieldset class="space-y-4 rounded-lg border border-border p-4" data-foreclosure-fields hidden>
        <legend class="px-1 text-sm font-semibold">Versteigerungsdaten</legend>
        <div class="grid gap-4 md:grid-cols-2">
          <div class="space-y-2">
            <Label for="courtName">Gericht *</Label>
            <Input id="courtName" name="foreclosureCourtName" placeholder="Bezirksgericht" data-foreclosure-required disabled />
          </div>
          <div class="space-y-2">
            <Label for="fileNumber">Aktenzeichen *</Label>
            <Input id="fileNumber" name="foreclosureFileNumber" placeholder="Geschäftszahl" data-foreclosure-required disabled />
          </div>
          <div class="space-y-2">
            <Label for="auctionDate">Versteigerungstermin *</Label>
            <Input id="auctionDate" name="foreclosureAuctionDate" type="datetime-local" data-foreclosure-required disabled />
          </div>
          <div class="space-y-2">
            <Label for="minimumBid">Mindestgebot (EUR) *</Label>
            <Input id="minimumBid" name="foreclosureMinimumBid" type="number" inputmode="numeric" min="1" step="1" placeholder="250000" data-foreclosure-required disabled />
          </div>
          <div class="space-y-2">
            <Label for="estimatedValue">Schätzwert (EUR)</Label>
            <Input id="estimatedValue" name="foreclosureEstimatedValue" type="number" inputmode="numeric" min="1" step="1" placeholder="500000" disabled />
          </div>
          <div class="space-y-2">
            <Label for="foreclosureStatus">Status</Label>
            <NativeSelect id="foreclosureStatus" name="foreclosureStatus" disabled>
              <option value="Scheduled">Terminiert</option>
              <option value="Pending">Anhaengig</option>
              <option value="InProgress">Laufend</option>
              <option value="Completed">Abgeschlossen</option>
              <option value="Cancelled">Aufgehoben</option>
            </NativeSelect>
          </div>
          <div class="space-y-2">
            <Label for="viewingDate">Besichtigung</Label>
            <Input id="viewingDate" name="foreclosureViewingDate" type="datetime-local" disabled />
          </div>
          <div class="space-y-2">
            <Label for="biddingDeadline">Gebotsfrist</Label>
            <Input id="biddingDeadline" name="foreclosureBiddingDeadline" type="datetime-local" disabled />
          </div>
          <div class="space-y-2">
            <Label for="ownershipShare">Eigentumsanteil</Label>
            <Input id="ownershipShare" name="foreclosureOwnershipShare" placeholder="z.B. 1/1" disabled />
          </div>
          <div class="space-y-2">
            <Label for="edictUrl">Edikt-Link</Label>
            <Input id="edictUrl" name="foreclosureEdictUrl" type="url" placeholder="https://..." disabled />
          </div>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          <Input name="foreclosureRegistrationNumber" placeholder="Einlagezahl" aria-label="Einlagezahl" disabled />
          <Input name="foreclosureCadastralMunicipality" placeholder="Katastralgemeinde" aria-label="Katastralgemeinde" disabled />
          <Input name="foreclosurePlotNumber" placeholder="Grundstuecksnummer" aria-label="Grundstuecksnummer" disabled />
          <Input name="foreclosureTotalArea" type="number" inputmode="numeric" min="1" step="1" placeholder="Gesamtflaeche m2" aria-label="Gesamtflaeche" disabled />
          <Input name="foreclosureBuildingArea" type="number" inputmode="numeric" min="1" step="1" placeholder="Bebaute Flaeche m2" aria-label="Bebaute Flaeche" disabled />
          <Input name="foreclosureZoningDesignation" placeholder="Flaechenwidmung" aria-label="Flaechenwidmung" disabled />
          <Input name="foreclosureBuildingCondition" placeholder="Gebaeudezustand" aria-label="Gebaeudezustand" disabled />
        </div>
        <div class="space-y-2">
          <Label for="foreclosureNotes">Hinweise</Label>
          <Textarea id="foreclosureNotes" name="foreclosureNotes" class="min-h-24" disabled />
        </div>
      </fieldset>
      <div class="rounded-lg border border-dashed border-border p-4" data-property-image-zone>
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <Label for="propertyImages">Fotos *</Label>
            <p class="mt-1 text-sm text-muted-foreground" data-property-image-count>Fotos 0 / 20</p>
          </div>
          <label class="inline-flex h-10 cursor-pointer items-center justify-center gap-2 rounded-md bg-foreground px-4 text-sm font-semibold text-background">
            <PhotoPlusIcon class="size-4" aria-hidden="true" />
            Fotos auswaehlen
            <input id="propertyImages" name="propertyImages" type="file" accept="image/jpeg,image/png,image/webp" multiple class="sr-only" data-property-images />
          </label>
        </div>
        <div class="mt-4 hidden grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5" data-property-image-grid></div>
        <p class="mt-3 text-xs text-muted-foreground" data-property-image-help>Mindestens ein Foto ist fuer ein veroeffentlichtes Inserat erforderlich. Maximal 20 Bilder.</p>
      </div>
      <p class="hidden text-sm" data-form-status></p>
      <div class="grid gap-3 sm:grid-cols-2">
        <Button href="/" variant="outline" class="w-full">Abbrechen</Button>
        <Button type="submit" class="w-full">Speichern</Button>
      </div>
    </form>
  </section>
</BaseLayout>
