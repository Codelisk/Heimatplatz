---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { guidePages } from "@/data/guide-pages";
import { searchIntents } from "@/data/search-intents";
import { upperAustriaRegions } from "@/data/upper-austria-regions";
import { breadcrumbSchema } from "@/lib/seo";

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Immobilien Ratgeber Oberösterreich",
  description:
    "Ratgeber fuer Immobilien in Oberösterreich: Haus kaufen, Wohnung kaufen, Grundstueck kaufen, privat verkaufen und Zwangsversteigerungen verstehen.",
  mainEntity: {
    "@type": "ItemList",
    itemListElement: guidePages.map((guide, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: guide.h1,
      url: new URL(guide.canonicalPath, Astro.site).toString(),
    })),
  },
};
---

<BaseLayout
  title="Immobilien Ratgeber Oberösterreich"
  description="Ratgeber fuer Immobilien in Oberösterreich: Haus kaufen, Wohnung kaufen, Grundstueck kaufen und Zwangsversteigerungen verstehen."
  canonicalPath="/ratgeber/"
  structuredData={[
    breadcrumbSchema([
      { name: "Heimatplatz", url: new URL("/", Astro.site).toString() },
      { name: "Ratgeber", url: new URL("/ratgeber/", Astro.site).toString() },
    ]),
    itemListSchema,
  ]}
>
  <section class="border-b border-border bg-muted/30">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
      <p class="text-sm font-bold uppercase text-muted-foreground">Ratgeber</p>
      <h1 class="mt-3 max-w-4xl text-4xl font-bold leading-tight">Immobilienwissen fuer Oberösterreich</h1>
      <p class="mt-4 max-w-3xl text-base leading-7 text-muted-foreground">
        Praktische Orientierung fuer Hauskauf, Wohnungskauf, Grundstuecke, private Inserate
        und gerichtliche Immobilienversteigerungen in Oberösterreich.
      </p>
    </div>
  </section>

  <section class="mx-auto grid max-w-7xl gap-10 px-4 py-10 sm:px-6 lg:grid-cols-[minmax(0,1fr)_340px] lg:px-8">
    <div>
      <h2 class="text-2xl font-bold">Ratgeber nach Thema</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {guidePages.map((guide) => (
          <article class="rounded-lg border border-border bg-card p-5 hover:border-foreground">
            <p class="text-xs font-bold uppercase text-muted-foreground">{guide.readingTime}</p>
            <h3 class="mt-2 text-xl font-bold">
              <a href={guide.canonicalPath}>{guide.h1}</a>
            </h3>
            <p class="mt-3 text-sm leading-6 text-muted-foreground">{guide.description}</p>
            <a class="mt-4 inline-flex text-sm font-semibold hover:underline" href={guide.canonicalPath}>
              Ratgeber lesen
            </a>
          </article>
        ))}
      </div>

      <section class="mt-10 rounded-lg border border-border bg-card p-6">
        <h2 class="text-xl font-bold">Warum regionale Ratgeberseiten wichtig sind</h2>
        <p class="mt-3 text-sm leading-6 text-muted-foreground">
          Immobilienfragen sind in Oberösterreich stark regional. Ein Haus in Linz-Land,
          eine Wohnung in Wels, ein Baugrund in Gmunden oder eine Zwangsversteigerung in
          Perg werden mit anderen Suchbegriffen und Entscheidungskriterien verglichen.
        </p>
      </section>
    </div>

    <aside class="space-y-5 self-start lg:sticky lg:top-20">
      <section class="rounded-lg border border-border bg-card p-5">
        <h2 class="text-lg font-bold">Direkt suchen</h2>
        <ul class="mt-4 space-y-3 text-sm text-muted-foreground">
          {searchIntents.map((intent) => (
            <li><a class="hover:text-foreground" href={intent.canonicalPath}>{intent.title}</a></li>
          ))}
          <li><a class="hover:text-foreground" href="/zwangsversteigerungen/">Zwangsversteigerungen Oberösterreich</a></li>
        </ul>
      </section>

      <section class="rounded-lg border border-border bg-card p-5">
        <h2 class="text-lg font-bold">Wichtige Regionen</h2>
        <ul class="mt-4 space-y-3 text-sm text-muted-foreground">
          {upperAustriaRegions.slice(0, 8).map((region) => (
            <li><a class="hover:text-foreground" href={`/immobilien/oberoesterreich/${region.slug}/`}>{region.name}</a></li>
          ))}
          <li><a class="hover:text-foreground" href="/immobilien/oberoesterreich/">Alle Bezirke</a></li>
        </ul>
      </section>
    </aside>
  </section>
</BaseLayout>
