---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Button } from "@/components/starwind/button";
---

<BaseLayout title="Mein Konto" description="Profil und Konto fuer Heimatplatz verwalten." canonicalPath="/profil/" noindex>
  <section class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="rounded-lg border border-border bg-card p-5" data-guest-only>
      <p class="text-sm text-muted-foreground">Nicht angemeldet</p>
      <p class="mt-2 text-lg font-semibold">Melden Sie sich an, um Profil, Favoriten und Inserate zu verwalten.</p>
      <Button href="/anmelden/" variant="default" class="mt-5">Anmelden</Button>
    </div>

    <div class="mt-5 rounded-lg border border-border bg-card p-5" data-auth-only hidden>
      <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex items-center gap-4">
          <div class="grid size-16 shrink-0 place-items-center rounded-full bg-foreground text-xl font-bold text-background" data-auth-initials>?</div>
          <div>
            <p class="text-sm text-muted-foreground">Angemeldet als</p>
            <p class="mt-1 text-xl font-semibold" data-auth-name>Nicht angemeldet</p>
            <p class="mt-1 text-sm text-muted-foreground" data-auth-email></p>
            <p class="mt-3 inline-flex rounded-full bg-muted px-3 py-1 text-xs font-semibold" data-auth-role-badge></p>
          </div>
        </div>
        <Button type="button" variant="outline" data-logout>Abmelden</Button>
      </div>
    </div>

    <div class="mt-5 grid gap-4 md:grid-cols-2" data-auth-only hidden>
      <div class="rounded-lg border border-border p-5" data-auth-role-buyer hidden>
        <p class="text-sm text-muted-foreground">Rolle</p>
        <h2 class="mt-1 text-lg font-semibold">Kaeufer</h2>
        <p class="mt-2 text-sm text-muted-foreground">Immobilien suchen, Favoriten speichern und Anbieter kontaktieren.</p>
      </div>
      <div class="rounded-lg border border-border p-5" data-auth-role-seller hidden>
        <p class="text-sm text-muted-foreground">Rolle</p>
        <h2 class="mt-1 text-lg font-semibold">Verkaeufer</h2>
        <p class="mt-2 text-sm text-muted-foreground">Eigene Immobilien anbieten, bearbeiten und verwalten.</p>
      </div>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <a class="rounded-lg border border-border p-5 hover:border-foreground" href="/favoriten/">Favoriten</a>
      <a class="rounded-lg border border-border p-5 hover:border-foreground" href="/meine-immobilien/">Meine Immobilien</a>
      <a class="rounded-lg border border-border p-5 hover:border-foreground" href="/benachrichtigungen/">Benachrichtigungen</a>
    </div>
  </section>
</BaseLayout>
