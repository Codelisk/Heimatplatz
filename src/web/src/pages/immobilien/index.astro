---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PropertySearchApp from "@/components/properties/PropertySearchApp.astro";
import { fetchApiProperties, getApiPropertyPath } from "@/features/properties/live-api";
import { breadcrumbSchema } from "@/lib/seo";

const properties = (await getCollection("properties")).sort(
  (a, b) => b.data.updatedAt.valueOf() - a.data.updatedAt.valueOf(),
);
const apiProperties = await fetchApiProperties({ pageSize: 24 });
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Immobilien in Oberösterreich suchen",
  description: "Immobilien in Oberösterreich suchen: Haeuser, Wohnungen, Grundstuecke und Zwangsversteigerungen.",
  mainEntity: {
    "@type": "ItemList",
    itemListElement: [
      ...properties.map((property, index) => ({
        "@type": "ListItem",
        position: index + 1,
        url: new URL(`/immobilien/${property.data.slug}/`, Astro.site).toString(),
        name: property.data.title,
      })),
      ...apiProperties.map((property, index) => ({
        "@type": "ListItem",
        position: properties.length + index + 1,
        url: new URL(getApiPropertyPath(property), Astro.site).toString(),
        name: property.Title,
      })),
    ],
  },
};
---

<BaseLayout
  title="Immobilien in Oberösterreich suchen"
  description="Immobilien in Oberösterreich suchen: Haeuser, Wohnungen, Grundstuecke und Zwangsversteigerungen in Linz, Wels, Steyr, Gmunden, Voecklabruck und Linz-Land."
  canonicalPath="/immobilien/"
  structuredData={[
    breadcrumbSchema([
      { name: "Heimatplatz", url: new URL("/", Astro.site).toString() },
      { name: "Immobilien", url: new URL("/immobilien/", Astro.site).toString() },
    ]),
    itemListSchema,
  ]}
>
  <PropertySearchApp
    properties={properties}
    apiProperties={apiProperties}
    introTitle="Immobilien in Oberösterreich suchen"
    introDescription="Filtere nach Ort, Anbieter und Immobilientyp und finde passende Häuser, Wohnungen, Grundstücke und Versteigerungsobjekte in den Bezirken Oberösterreichs."
    showIntro
  />
</BaseLayout>
