---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getLocalityPath,
  getRegionLocalities,
  localitySearchPages,
} from "@/data/locality-search-pages";
import { upperAustriaRegions } from "@/data/upper-austria-regions";
import { breadcrumbSchema, faqSchema } from "@/lib/seo";

const localitiesByInitial = Object.entries(
  localitySearchPages.reduce<Record<string, typeof localitySearchPages>>((groups, locality) => {
    const initial = locality.name.slice(0, 1).toLocaleUpperCase("de-AT");
    groups[initial] = groups[initial] ?? [];
    groups[initial].push(locality);
    return groups;
  }, {}),
).sort(([a], [b]) => a.localeCompare(b, "de-AT"));

const regionGroups = upperAustriaRegions.map((region) => ({
  region,
  localities: getRegionLocalities(region.slug),
}));

const faqItems = [
  {
    question: "Welche Orte in Oberösterreich deckt Heimatplatz ab?",
    answer:
      "Der Orte-Hub verlinkt regionale Immobilienseiten fuer Staedte, Bezirkszentren, Ortsteile und wichtige Gemeinden in Oberösterreich.",
  },
  {
    question: "Warum gibt es eigene Immobilienseiten fuer Orte?",
    answer:
      "Eigene Ortsseiten helfen bei konkreten Suchen wie Haus kaufen Linz, Wohnung Wels oder Grundstueck Gmunden und fuehren passende Angebote, Regionen und Filter zusammen.",
  },
  {
    question: "Sind die Ortsseiten fuer Google sichtbar?",
    answer:
      "Ja. Die Ortsseiten und dieser Orte-Hub sind indexierbar, intern verlinkt und werden ueber die Sitemap auffindbar gemacht.",
  },
  {
    question: "Kann ich von einer Ortsseite direkt suchen?",
    answer:
      "Ja. Jede Ortsseite verlinkt zur Immobiliensuche mit passenden regionalen Einstiegen fuer Haus, Wohnung, Grundstueck und Zwangsversteigerungen.",
  },
];

const structuredData = [
  breadcrumbSchema([
    { name: "Heimatplatz", url: new URL("/", Astro.site).toString() },
    { name: "Immobilien", url: new URL("/immobilien/", Astro.site).toString() },
    { name: "Orte", url: new URL("/immobilien/orte/", Astro.site).toString() },
  ]),
  faqSchema(faqItems),
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "Immobilien-Orte in Oberösterreich",
    itemListElement: localitySearchPages.map((locality, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: `Immobilien ${locality.name}`,
      url: new URL(getLocalityPath(locality.slug), Astro.site).toString(),
    })),
  },
];
---

<BaseLayout
  title="Immobilien Orte Oberösterreich A-Z"
  description="Alle regionalen Immobilien-Ortsseiten fuer Oberösterreich: Linz, Wels, Steyr, Gmunden, Voecklabruck, Innviertel, Muehlviertel und weitere Orte."
  canonicalPath="/immobilien/orte/"
  structuredData={structuredData}
>
  <section class="border-b border-border bg-muted/35">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
      <p class="text-sm font-bold uppercase text-muted-foreground">Orte A-Z</p>
      <h1 class="mt-3 text-4xl font-bold">Immobilien in Oberösterreich nach Ort</h1>
      <p class="mt-4 max-w-3xl text-base leading-7 text-muted-foreground">
        Lokale Einstiegsseiten fuer Immobiliensuchen in Oberösterreich: Haeuser,
        Wohnungen, Grundstuecke und Zwangsversteigerungen nach Stadt, Gemeinde,
        Ortsteil, Bezirk und Region.
      </p>
      <div class="mt-6 flex flex-wrap gap-2 text-sm">
        <a class="rounded-md bg-foreground px-4 py-2 font-semibold text-background" href="/immobilien/">
          Suche oeffnen
        </a>
        <a class="rounded-md border border-border bg-card px-4 py-2 font-semibold" href="/immobilien/oberoesterreich/">
          Bezirke ansehen
        </a>
        <a class="rounded-md border border-border bg-card px-4 py-2 font-semibold" href="/zwangsversteigerungen/">
          Zwangsversteigerungen
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border border-border bg-card p-5">
        <p class="text-3xl font-bold">{localitySearchPages.length}</p>
        <p class="mt-2 text-sm font-semibold">Ortsseiten</p>
        <p class="mt-2 text-sm leading-6 text-muted-foreground">
          Indexierbare Seiten fuer lokale Immobilienbegriffe in Oberösterreich.
        </p>
      </div>
      <div class="rounded-lg border border-border bg-card p-5">
        <p class="text-3xl font-bold">{upperAustriaRegions.length}</p>
        <p class="mt-2 text-sm font-semibold">Regionen und Bezirke</p>
        <p class="mt-2 text-sm leading-6 text-muted-foreground">
          Struktur nach Statutarstadt, Bezirk, Gemeinde und Pendlerregion.
        </p>
      </div>
      <div class="rounded-lg border border-border bg-card p-5">
        <p class="text-3xl font-bold">4</p>
        <p class="mt-2 text-sm font-semibold">Sucharten</p>
        <p class="mt-2 text-sm leading-6 text-muted-foreground">
          Haus, Wohnung, Grundstueck und Zwangsversteigerung regional auffindbar.
        </p>
      </div>
    </div>

    <section class="mt-12">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 class="text-2xl font-bold">Alle Orte von A-Z</h2>
          <p class="mt-3 max-w-3xl text-sm leading-6 text-muted-foreground">
            Direkte Links zu lokalen Immobilienseiten fuer Oberösterreich. Jede
            Seite buendelt passende regionale Suchbegriffe, Angebote und interne
            Links zu benachbarten Orten.
          </p>
        </div>
        <p class="text-sm text-muted-foreground">{localitiesByInitial.length} Anfangsbuchstaben</p>
      </div>

      <div class="mt-6 grid gap-4 lg:grid-cols-2">
        {localitiesByInitial.map(([initial, localities]) => (
          <section class="rounded-lg border border-border bg-card p-5">
            <h3 class="text-xl font-bold">{initial}</h3>
            <ul class="mt-4 grid gap-2 sm:grid-cols-2">
              {localities.map((locality) => (
                <li>
                  <a class="group block rounded-md border border-transparent px-2 py-2 hover:border-border hover:bg-muted/50" href={getLocalityPath(locality.slug)}>
                    <span class="block text-sm font-semibold group-hover:underline">Immobilien {locality.name}</span>
                    <span class="mt-1 block text-xs text-muted-foreground">{locality.regionName}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold">Orte nach Bezirk und Region</h2>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-muted-foreground">
        Wer nach Immobilien in einer bestimmten Region sucht, findet hier die
        wichtigsten lokalen Einstiege pro Bezirk und Statutarstadt.
      </p>
      <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {regionGroups.map(({ region, localities }) => (
          <section class="rounded-lg border border-border bg-card p-5">
            <a class="text-lg font-bold hover:underline" href={`/immobilien/oberoesterreich/${region.slug}/`}>
              {region.title}
            </a>
            <p class="mt-3 text-sm leading-6 text-muted-foreground">{region.description}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {localities.map((locality) => (
                <a class="rounded-full border border-border px-3 py-1.5 text-xs font-medium hover:border-foreground" href={getLocalityPath(locality.slug)}>
                  {locality.name}
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>

    <section class="mt-12 rounded-lg border border-border bg-muted/35 p-5">
      <h2 class="text-2xl font-bold">Haeufige Fragen zu Immobilien-Orten</h2>
      <div class="mt-5 divide-y divide-border">
        {faqItems.map((item) => (
          <details class="group py-4">
            <summary class="cursor-pointer text-base font-semibold">{item.question}</summary>
            <p class="mt-3 text-sm leading-6 text-muted-foreground">{item.answer}</p>
          </details>
        ))}
      </div>
    </section>
  </section>
</BaseLayout>
