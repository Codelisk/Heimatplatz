---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PropertySearchApp from "@/components/properties/PropertySearchApp.astro";
import {
  getLocalityPath,
  getRelatedLocalities,
  localitySearchPages,
  type LocalitySearchPage,
} from "@/data/locality-search-pages";
import { getRegionSearchPath, regionSearchIntents } from "@/data/region-search-intents";
import { upperAustriaRegions } from "@/data/upper-austria-regions";
import { fetchMunicipalityRegionSlugs } from "@/features/locations/api";
import { getApiPropertyRegionSlug, slugifyLocation } from "@/features/locations/region-match";
import {
  API_PROPERTY_BUILD_LIMIT,
  fetchApiProperties,
  getApiPropertyPath,
} from "@/features/properties/live-api";
import { breadcrumbSchema, faqSchema } from "@/lib/seo";

export async function getStaticPaths() {
  return localitySearchPages.map((locality) => ({
    params: { slug: locality.slug },
    props: { locality },
  }));
}

const { locality } = Astro.props as { locality: LocalitySearchPage };
const region = upperAustriaRegions.find((item) => item.slug === locality.regionSlug);
if (!region) throw new Error(`Unknown locality region: ${locality.regionSlug}`);

function matchesLocalityText(value: string) {
  return slugifyLocation(value).includes(locality.baseSlug);
}

const allProperties = await getCollection("properties");
const properties = allProperties
  .filter((property) => property.data.regionSlug === locality.regionSlug)
  .filter((property) =>
    matchesLocalityText([
      property.data.title,
      property.data.description,
      property.data.location,
      property.data.address,
      property.data.postalCode,
      property.data.highlights.join(" "),
      property.data.features.join(" "),
    ].join(" ")),
  )
  .sort((a, b) => b.data.updatedAt.valueOf() - a.data.updatedAt.valueOf());

const [apiProperties, municipalityRegionSlugs] = await Promise.all([
  fetchApiProperties({ pageSize: API_PROPERTY_BUILD_LIMIT }),
  fetchMunicipalityRegionSlugs(),
]);
const liveProperties = apiProperties
  .filter((property) => getApiPropertyRegionSlug(property, municipalityRegionSlugs, region) === locality.regionSlug)
  .filter((property) =>
    matchesLocalityText([
      property.Title,
      property.Description ?? "",
      property.City,
      property.Address,
      property.PostalCode,
      property.SellerName,
      property.SourceName ?? "",
      property.Features?.join(" ") ?? "",
    ].join(" ")),
  )
  .slice(0, 18);

const canonicalPath = getLocalityPath(locality.slug);
const canonicalUrl = new URL(canonicalPath, Astro.site).toString();
const relatedLocalities = getRelatedLocalities(locality, 10);
const primaryRegionIntents = regionSearchIntents.slice(0, 4);
const offerCount = properties.length + liveProperties.length;
const faqItems = [
  {
    question: `Welche Immobilien finde ich in ${locality.name}?`,
    answer:
      `Heimatplatz zeigt Haeuser, Wohnungen, Grundstuecke und Versteigerungsobjekte, die zu ${locality.name} oder zur Region ${locality.regionName} passen.`,
  },
  {
    question: `Wie suche ich gezielt nach Haus, Wohnung oder Grundstueck in ${locality.name}?`,
    answer:
      `Die Schnelllinks auf dieser Seite oeffnen die Immobiliensuche bereits mit ${locality.name} und dem passenden Objekttyp. Danach kannst du Anbieter, Zeitraum und Sortierung weiter anpassen.`,
  },
  {
    question: `Warum sehe ich manchmal wenige Treffer fuer ${locality.name}?`,
    answer:
      "Ein Angebot wird nur lokal zugeordnet, wenn Titel, Adresse, Ort oder Detaildaten klar passen. Neue Live-Angebote erscheinen automatisch, sobald die Daten zur Suche passen.",
  },
  {
    question: `Welche Orte rund um ${locality.name} sind relevant?`,
    answer:
      `Die nahegelegenen Ortsseiten in der Region ${locality.regionName} helfen beim Vergleich von Immobilienpreisen, Angebotstypen und Lagealternativen.`,
  },
];
const placeName =
  locality.name === locality.regionName
    ? `${locality.name}, Oberösterreich`
    : `${locality.name}, ${locality.regionName}, Oberösterreich`;
const localityContext =
  locality.name === locality.regionName
    ? `${locality.name} ist eine zentrale Immobiliensuche in Oberösterreich`
    : `${locality.name} gehoert zur Region ${locality.regionName}`;
const itemListElement = [
  ...properties.map((property, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: new URL(`/immobilien/${property.data.slug}/`, Astro.site).toString(),
    name: property.data.title,
  })),
  ...liveProperties.map((property, index) => ({
    "@type": "ListItem",
    position: properties.length + index + 1,
    url: new URL(getApiPropertyPath(property), Astro.site).toString(),
    name: property.Title,
  })),
];
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: locality.h1,
  description: locality.description,
  keywords: locality.keywords,
  about: {
    "@type": "Place",
    name: placeName,
  },
  mainEntity: {
    "@type": "ItemList",
    itemListElement,
  },
};
---

<BaseLayout
  title={locality.title}
  description={locality.description}
  canonicalPath={canonicalPath}
  structuredData={[
    breadcrumbSchema([
      { name: "Heimatplatz", url: new URL("/", Astro.site).toString() },
      { name: "Immobilien", url: new URL("/immobilien/", Astro.site).toString() },
      { name: "Oberösterreich", url: new URL("/immobilien/oberoesterreich/", Astro.site).toString() },
      { name: locality.regionName, url: new URL(`/immobilien/oberoesterreich/${locality.regionSlug}/`, Astro.site).toString() },
      { name: locality.name, url: canonicalUrl },
    ]),
    collectionSchema,
    faqSchema(faqItems),
  ]}
>
  <PropertySearchApp
    properties={properties}
    apiProperties={liveProperties}
    introTitle={locality.h1}
    introDescription={locality.description}
    presetQuery={locality.name}
    showIntro
  />

  <section class="border-t border-border bg-muted/25">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 py-10 sm:px-6 lg:grid-cols-[1fr_320px] lg:px-8">
      <div>
        <h2 class="text-2xl font-bold">Immobiliensuche in {locality.name}</h2>
        <div class="mt-4 grid gap-4 text-sm leading-6 text-muted-foreground md:grid-cols-2">
          <p class="rounded-lg border border-border bg-card p-4">
            {localityContext}. Die Seite buendelt passende
            Haeuser, Wohnungen, Grundstuecke und Versteigerungsobjekte aus statischen Objektseiten
            und aktuellen Live-Angeboten.
          </p>
          <p class="rounded-lg border border-border bg-card p-4">
            Fuer lokale Google-Suchen wie {locality.keywords.slice(0, 3).join(", ")} werden Ort,
            Bezirk, Immobilientyp und Detailseiten intern verknuepft.
          </p>
        </div>

        <h2 class="mt-8 text-xl font-bold">Haeufige Suchen fuer {locality.name}</h2>
        <div class="mt-4 flex flex-wrap gap-2">
          {[
            ["Haus kaufen", "house"],
            ["Wohnung kaufen", "apartment"],
            ["Grundstueck kaufen", "land"],
            ["Zwangsversteigerungen", "foreclosure"],
          ].map(([label, type]) => (
            <a
              class="rounded-full border border-border bg-card px-3 py-1.5 text-sm font-medium hover:border-foreground"
              href={`/immobilien/?q=${encodeURIComponent(locality.name)}&type=${type}`}
            >
              {label} {locality.name}
            </a>
          ))}
        </div>

        {offerCount === 0 && (
          <div class="mt-8 rounded-lg border border-border bg-card p-5">
            <h2 class="text-lg font-bold">Neue Angebote in {locality.name}</h2>
            <p class="mt-3 text-sm leading-6 text-muted-foreground">
              Aktuell sind keine direkt zugeordneten Angebote sichtbar. Die Suche bleibt indexierbar
              und zeigt neue Objekte, sobald Titel, Adresse oder Ort zu {locality.name} passen.
            </p>
          </div>
        )}

        <section class="mt-8" aria-labelledby="locality-faq">
          <h2 id="locality-faq" class="text-xl font-bold">Haeufige Fragen zu Immobilien in {locality.name}</h2>
          <div class="mt-4 grid gap-3">
            {faqItems.map((item) => (
              <details class="rounded-lg border border-border bg-card p-4">
                <summary class="cursor-pointer text-sm font-semibold">{item.question}</summary>
                <p class="mt-3 text-sm leading-6 text-muted-foreground">{item.answer}</p>
              </details>
            ))}
          </div>
        </section>
      </div>

      <aside class="self-start rounded-lg border border-border bg-card p-5">
        <h2 class="text-lg font-bold">Region {locality.regionName}</h2>
        <ul class="mt-4 space-y-3 text-sm text-muted-foreground">
          <li>
            <a class="hover:text-foreground" href={`/immobilien/oberoesterreich/${locality.regionSlug}/`}>
              Alle Immobilien {locality.regionName}
            </a>
          </li>
          {primaryRegionIntents.map((intent) => (
            <li>
              <a class="hover:text-foreground" href={getRegionSearchPath(locality.regionSlug, intent.slug)}>
                {intent.label} {locality.regionName}
              </a>
            </li>
          ))}
        </ul>

        <div class="mt-6 border-t border-border pt-5">
          <h2 class="text-lg font-bold">Nahe Orte</h2>
          <ul class="mt-4 space-y-2 text-sm text-muted-foreground">
            {relatedLocalities.map((item) => (
              <li>
                <a class="hover:text-foreground" href={getLocalityPath(item.slug)}>
                  Immobilien {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
