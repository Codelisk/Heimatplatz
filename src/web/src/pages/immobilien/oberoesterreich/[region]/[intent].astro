---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ApiPropertyCard from "@/components/properties/ApiPropertyCard.astro";
import PropertyPreviewCard from "@/components/properties/PropertyPreviewCard.astro";
import { getLocalityPath, getRegionLocalities } from "@/data/locality-search-pages";
import {
  filterApiPropertyForRegionSearch,
  filterStaticPropertyForRegionSearch,
  getRegionSearchPath,
  regionSearchIntents,
} from "@/data/region-search-intents";
import { upperAustriaRegions } from "@/data/upper-austria-regions";
import { fetchMunicipalityRegionSlugs } from "@/features/locations/api";
import { getApiPropertyRegionSlug } from "@/features/locations/region-match";
import {
  API_PROPERTY_BUILD_LIMIT,
  fetchApiProperties,
  getApiPropertyPath,
} from "@/features/properties/live-api";
import { breadcrumbSchema, faqSchema } from "@/lib/seo";

export async function getStaticPaths() {
  return upperAustriaRegions.flatMap((region) =>
    regionSearchIntents.map((intent) => ({
      params: { region: region.slug, intent: intent.slug },
      props: { region, intent },
    })),
  );
}

const { region, intent } = Astro.props;
const allProperties = await getCollection("properties");
const properties = allProperties.filter((property) =>
  property.data.regionSlug === region.slug && filterStaticPropertyForRegionSearch(property, intent),
);
const [apiProperties, municipalityRegionSlugs] = await Promise.all([
  fetchApiProperties({ pageSize: API_PROPERTY_BUILD_LIMIT }),
  fetchMunicipalityRegionSlugs(),
]);
const liveProperties = apiProperties
  .filter((property) => getApiPropertyRegionSlug(property, municipalityRegionSlugs, region) === region.slug)
  .filter((property) => filterApiPropertyForRegionSearch(property, intent))
  .slice(0, 18);
const offerCount = properties.length + liveProperties.length;
const canonicalPath = getRegionSearchPath(region.slug, intent.slug);
const canonicalUrl = new URL(canonicalPath, Astro.site).toString();
const relatedIntents = regionSearchIntents.filter((item) => item.slug !== intent.slug);
const localities = getRegionLocalities(region.slug, 10);
const faqItems = [
  {
    question: `Welche Treffer zeigt diese Seite fuer ${intent.label} in ${region.name}?`,
    answer:
      `${intent.description(region)} Die Ergebnisse werden aus lokalen Objektseiten und aktuellen Live-Angeboten fuer Oberösterreich gebuendelt.`,
  },
  {
    question: `Wie kann ich ${intent.label} in ${region.name} weiter filtern?`,
    answer:
      "Oeffne die Suche mit dem passenden Typ- und Bezirksfilter und grenze danach nach Ort, Zeitraum, Anbieter und Sortierung ein.",
  },
  {
    question: `Welche Orte in ${region.name} sind fuer diese Suche relevant?`,
    answer:
      `Die verlinkten Ortsseiten zeigen lokale Suchvarianten innerhalb von ${region.name}, damit du Alternativen in der Naehe schneller vergleichen kannst.`,
  },
  {
    question: "Werden neue Angebote automatisch sichtbar?",
    answer:
      "Ja. Neue Live-Angebote erscheinen auf den Suchseiten, sobald Ort, Region und Immobilientyp zu dieser Kombination passen.",
  },
];
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: intent.h1(region),
  description: intent.description(region),
  keywords: intent.keywords(region),
  about: {
    "@type": "Place",
    name: `${region.name}, Oberösterreich`,
  },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: [
      ...properties.map((property, index) => ({
        "@type": "ListItem",
        position: index + 1,
        url: new URL(`/immobilien/${property.data.slug}/`, Astro.site).toString(),
        name: property.data.title,
      })),
      ...liveProperties.map((property, index) => ({
        "@type": "ListItem",
        position: properties.length + index + 1,
        url: new URL(getApiPropertyPath(property), Astro.site).toString(),
        name: property.Title,
      })),
    ],
  },
};
---

<BaseLayout
  title={intent.title(region)}
  description={intent.description(region)}
  canonicalPath={canonicalPath}
  structuredData={[
    breadcrumbSchema([
      { name: "Heimatplatz", url: new URL("/", Astro.site).toString() },
      { name: "Immobilien", url: new URL("/immobilien/", Astro.site).toString() },
      { name: "Oberösterreich", url: new URL("/immobilien/oberoesterreich/", Astro.site).toString() },
      { name: region.name, url: new URL(`/immobilien/oberoesterreich/${region.slug}/`, Astro.site).toString() },
      { name: intent.label, url: canonicalUrl },
    ]),
    itemListSchema,
    faqSchema(faqItems),
  ]}
>
  <section class="border-b border-border bg-muted/35">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
      <p class="text-sm font-bold uppercase text-muted-foreground">Immobilien {region.name}</p>
      <h1 class="mt-3 max-w-4xl text-4xl font-bold leading-tight">{intent.h1(region)}</h1>
      <p class="mt-4 max-w-3xl text-base leading-7 text-muted-foreground">{intent.description(region)}</p>
      <div class="mt-5 flex flex-wrap gap-2">
        <a class="rounded-full bg-background px-3 py-1 text-sm hover:bg-card" href={`/immobilien/oberoesterreich/${region.slug}/`}>
          Alle Immobilien {region.name}
        </a>
        <a class="rounded-full bg-background px-3 py-1 text-sm hover:bg-card" href="/immobilien/oberoesterreich/">
          Alle Bezirke
        </a>
        <a class="rounded-full bg-background px-3 py-1 text-sm hover:bg-card" href="/immobilien/">
          Suche oeffnen
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto grid max-w-7xl gap-8 px-4 py-10 sm:px-6 lg:grid-cols-[1fr_320px] lg:px-8">
    <div>
      <h2 class="text-2xl font-bold">Aktuelle Treffer fuer {intent.label} in {region.name}</h2>
      {offerCount > 0 ? (
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          {properties.map((property) => <PropertyPreviewCard property={property} />)}
          {liveProperties.map((property) => <ApiPropertyCard property={property} />)}
        </div>
      ) : (
        <div class="mt-6 rounded-lg border border-border bg-card p-6">
          <p class="text-sm leading-6 text-muted-foreground">
            Fuer diese Kombination sind aktuell keine lokal zugeordneten Angebote sichtbar.
            Neue Inserate aus {region.name} erscheinen hier mit Ort, Preis, Flaeche und Detailansicht.
          </p>
          <a class="mt-4 inline-flex h-10 items-center rounded-md bg-foreground px-4 text-sm font-semibold text-background" href={`/immobilien/?type=${intent.presetType}&region=${region.slug}`}>
            Suche fuer {region.name} oeffnen
          </a>
        </div>
      )}

      <section class="mt-8 rounded-lg border border-border bg-card p-5">
        <h2 class="text-lg font-bold">Marktüberblick {region.name}</h2>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-muted-foreground">
          {intent.marketNotes(region).map((note) => <li>{note}</li>)}
          {region.marketNotes.map((note) => <li>{note}</li>)}
        </ul>
      </section>

      <section class="mt-8 rounded-lg border border-border bg-card p-5" aria-labelledby="region-intent-faq">
        <h2 id="region-intent-faq" class="text-lg font-bold">Haeufige Fragen zu {intent.label} in {region.name}</h2>
        <div class="mt-4 grid gap-3">
          {faqItems.map((item) => (
            <details class="rounded-md bg-muted p-3">
              <summary class="cursor-pointer text-sm font-semibold">{item.question}</summary>
              <p class="mt-3 text-sm leading-6 text-muted-foreground">{item.answer}</p>
            </details>
          ))}
        </div>
      </section>
    </div>

    <aside class="self-start rounded-lg border border-border bg-card p-5">
      <h2 class="text-lg font-bold">Weitere Suchen in {region.name}</h2>
      <ul class="mt-4 space-y-3 text-sm text-muted-foreground">
        {relatedIntents.map((item) => (
          <li><a class="hover:text-foreground" href={getRegionSearchPath(region.slug, item.slug)}>{item.label} {region.name}</a></li>
        ))}
        <li><a class="hover:text-foreground" href={`/immobilien/oberoesterreich/${region.slug}/`}>Alle Immobilien {region.name}</a></li>
      </ul>

      <div class="mt-6 border-t border-border pt-5">
        <h2 class="text-lg font-bold">Orte und Lagen</h2>
        <ul class="mt-4 space-y-2 text-sm text-muted-foreground">
          {localities.map((locality) => (
            <li>
              <a class="hover:text-foreground" href={getLocalityPath(locality.slug)}>
                {intent.label} {locality.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </aside>
  </section>
</BaseLayout>
