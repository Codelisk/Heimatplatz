---
import { getCollection } from "astro:content";
import SearchIntentPage from "@/components/properties/SearchIntentPage.astro";
import { filterPropertiesForSearchIntent, getSearchIntent } from "@/data/search-intents";

const intent = getSearchIntent("grundstueck-kaufen-oberoesterreich");
const properties = (await getCollection("properties"))
  .filter((property) => filterPropertiesForSearchIntent(property, intent))
  .sort((a, b) => b.data.updatedAt.valueOf() - a.data.updatedAt.valueOf());
---

<SearchIntentPage intent={intent} properties={properties} />
