---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ApiPropertyCard from "@/components/properties/ApiPropertyCard.astro";
import { searchIntents } from "@/data/search-intents";
import { fetchApiProperties, getApiPropertyPath } from "@/features/properties/live-api";
import { breadcrumbSchema } from "@/lib/seo";

const properties = await fetchApiProperties();
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Aktuelle Immobilienangebote Oberösterreich",
  description: "Aktuelle Immobilienangebote mit eigenen Objektseiten fuer Oberösterreich.",
  mainEntity: {
    "@type": "ItemList",
    itemListElement: properties.map((property, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: new URL(getApiPropertyPath(property), Astro.site).toString(),
      name: property.Title,
    })),
  },
};
---

<BaseLayout
  title="Aktuelle Immobilienangebote Oberösterreich"
  description="Aktuelle Immobilienangebote in Oberösterreich: Haeuser, Grundstuecke und weitere Objekte in den Bezirken und Statutarstaedten."
  canonicalPath="/immobilien/angebote/"
  structuredData={[
    breadcrumbSchema([
      { name: "Heimatplatz", url: new URL("/", Astro.site).toString() },
      { name: "Immobilien", url: new URL("/immobilien/", Astro.site).toString() },
      { name: "Angebote", url: new URL("/immobilien/angebote/", Astro.site).toString() },
    ]),
    itemListSchema,
  ]}
>
  <section class="border-b border-border bg-muted/35">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
      <p class="text-sm font-bold uppercase text-muted-foreground">Aktuelle Angebote</p>
      <h1 class="mt-3 text-4xl font-bold">Aktuelle Immobilienangebote in Oberösterreich</h1>
      <p class="mt-4 max-w-3xl text-base leading-7 text-muted-foreground">
        Häuser, Grundstücke, Wohnungen und weitere Immobilienangebote aus Oberösterreich
        mit eigenen Objektseiten, Eckdaten und Anbieterhinweisen.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    {properties.length > 0 ? (
      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {properties.map((property) => <ApiPropertyCard property={property} />)}
      </div>
    ) : (
      <div class="rounded-lg border border-border bg-card p-8">
        <h2 class="text-2xl font-bold">Keine aktuellen Angebote verfügbar</h2>
        <p class="mt-3 text-sm leading-6 text-muted-foreground">
          Die Immobiliensuche bleibt verfügbar und zeigt passende Ergebnisse, sobald neue
          Angebote vorliegen.
        </p>
        <a class="mt-5 inline-flex h-10 items-center rounded-md bg-foreground px-4 text-sm font-semibold text-background" href="/immobilien/">
          Zur Immobiliensuche
        </a>
      </div>
    )}
  </section>

  <section class="border-t border-border bg-muted/25">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold">Weitere Suchseiten fuer Oberösterreich</h2>
      <div class="mt-5 grid gap-4 md:grid-cols-3">
        {searchIntents.map((intent) => (
          <a class="rounded-lg border border-border bg-card p-5 hover:border-foreground" href={intent.canonicalPath}>
            <h3 class="text-lg font-bold">{intent.title}</h3>
            <p class="mt-3 text-sm leading-6 text-muted-foreground">{intent.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
