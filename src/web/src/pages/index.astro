---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PropertySearchApp from "@/components/properties/PropertySearchApp.astro";
import { fetchApiProperties } from "@/features/properties/live-api";

const apiProperties = await fetchApiProperties({ pageSize: 24 });
---

<BaseLayout
  title="Heimatplatz"
  description="Immobilien in Oberoesterreich finden: Haeuser, Wohnungen, Grundstuecke und Zwangsversteigerungen mit Filtern und Push-Benachrichtigungen."
  canonicalPath="/"
>
  <PropertySearchApp apiProperties={apiProperties} />
</BaseLayout>
