<pages:BasePage x:Class="Heimatplatz.Features.Properties.Presentation.BlockedPage"
      x:Name="RootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Heimatplatz.Features.Properties.Presentation"
      xmlns:controls="using:Heimatplatz.Features.Properties.Controls"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uc="using:UnoFramework.Controls"
      xmlns:pages="using:UnoFramework.Pages"
      NavigationCacheMode="Disabled">

    <!--
    BlockedPage - User's Blocked Properties
    Zeigt alle blockierten Immobilien des eingeloggten Käufers
    Blockierte Immobilien werden aus der Hauptliste ausgeblendet
    -->

    <Grid Background="{ThemeResource BackgroundBrush}">

        <uc:BusyOverlay IsBusy="{Binding IsBusy}"
                        BusyMessage="{Binding BusyMessage}">

            <Grid>
                <!-- Empty State -->
                <StackPanel x:Name="EmptyState"
                            Visibility="Collapsed"
                            Spacing="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <FontIcon Glyph="{Binding EmptyStateIcon}"
                              FontSize="64"
                              Foreground="{ThemeResource OnSurfaceVariantBrush}"
                              HorizontalAlignment="Center" />

                    <TextBlock Text="{Binding EmptyStateTitle}"
                               Style="{StaticResource TitleMediumTextBlockStyle}"
                               Foreground="{ThemeResource OnSurfaceBrush}"
                               HorizontalAlignment="Center" />

                    <TextBlock Text="{Binding EmptyStateDescription}"
                               Style="{StaticResource BodyMediumTextBlockStyle}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="400" />
                </StackPanel>

                <!-- Content Area -->
                <ScrollViewer x:Name="ContentArea" Visibility="Collapsed">
                    <utu:AutoLayout Orientation="Vertical"
                                    Spacing="16"
                                    Padding="{utu:Responsive Narrowest='16', Normal='24,24,24,40'}"
                                    utu:SafeArea.Insets="Bottom">

                        <!-- Blocked Properties Grid -->
                        <ItemsRepeater ItemsSource="{Binding Properties}"
                                       utu:ItemsRepeaterExtensions.SupportsIncrementalLoading="True">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout Orientation="Horizontal"
                                                   MinItemWidth="240"
                                                   MinItemHeight="330"
                                                   MinRowSpacing="16"
                                                   MinColumnSpacing="16"
                                                   ItemsStretch="Fill" />
                            </ItemsRepeater.Layout>

                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <controls:PropertyCard Property="{Binding}"
                                                           Mode="Blocked"
                                                           CardClicked="OnPropertyCardClicked"
                                                           PropertyBlocked="OnPropertyBlocked"
                                                           Margin="0" />
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <!-- Loading Indicator for Pagination -->
                        <ProgressRing IsActive="{Binding Properties.IsLoading}"
                                      Visibility="{Binding Properties.HasMoreItems}"
                                      Width="32"
                                      Height="32"
                                      Margin="0,16,0,0"
                                      HorizontalAlignment="Center" />

                    </utu:AutoLayout>
                </ScrollViewer>
            </Grid>

        </uc:BusyOverlay>

    </Grid>

</pages:BasePage>
